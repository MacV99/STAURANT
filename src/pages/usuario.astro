---
import Layout1 from "../layouts/Layout1.astro";
import SortBar from "../components/SortBar.astro";
import RestaurantCard from "../components/RestaurantCard.astro";
import RestaurantHeader from "../components/RestaurantHeader.astro";
import DishCard from "../components/DishCard.astro";
import ConfirmDialog from "../components/ConfirmDialog.astro";
import type { Restaurant, Dish } from "../lib/data";

const tplRestaurant: Restaurant = {
  id: "",
  name: "",
  status: "visited",
  notes: " ",
  createdAt: "",
  updatedAt: "",
  officialRestaurantId: null,
};
const tplDish: Dish = {
  id: "",
  restaurantId: "",
  typeId: null,
  name: "",
  rating: 5,
  notes: " ",
  createdAt: "",
  updatedAt: "",
  officialDishId: null,
};
---

<Layout1 title="Perfil · STAURANT">
  <div class="usuario-page flex-column">
    <!-- ── Cinta superior: breadcrumb + botón de amistad ── -->
    <div id="usuario-ribbon" class="usuario-ribbon texture-dotted flex-row">
      <button id="usuario-back" class="u-ribbon-back" type="button" aria-label="Atrás">
        <i class="bi bi-arrow-left"></i>
      </button>
      <div id="usuario-crumb" class="u-crumb flex-row"></div>
      <div id="usuario-friend-slot" class="u-friend-slot flex-row"></div>
    </div>

    <!-- ── Vista lista de restaurantes ── -->
    <div id="usuario-list-view" class="usuario-inner flex-column">
      <div class="usuario-sort-wrap" id="usuario-sort-wrap" hidden>
        <SortBar
          pills={[
            { field: "rating", label: "Rating" },
            { field: "name", label: "Nombre" },
            { field: "date", label: "Creación" },
          ]}
        />
      </div>
      <div id="usuario-restaurants" class="flex-column"></div>
    </div>

    <!-- ── Vista detalle de un restaurante ── -->
    <div id="usuario-detail-view" class="usuario-inner flex-column" hidden>
      <div id="usuario-detail-header"></div>
      <div class="usuario-dishes-section flex-column">
        <h2 class="usuario-dishes-title">Platos</h2>
        <div id="usuario-detail-dishes" class="flex-column"></div>
      </div>
    </div>
  </div>

  <!-- Templates renderizados por Astro (conservan su CSS scoped); el JS los clona -->
  <template id="tpl-user-restaurant-card">
    <RestaurantCard restaurant={tplRestaurant} avg={null} dishCount={0} />
  </template>
  <template id="tpl-user-restaurant-header">
    <RestaurantHeader restaurant={tplRestaurant} avg={5} dishCount={0} />
  </template>
  <template id="tpl-user-dish-card">
    <DishCard dish={tplDish} typeName="..." />
  </template>

  <ConfirmDialog />
</Layout1>

<style>
  /* `hidden` debe ganar sobre `.flex-column { display:flex }`. */
  [hidden] {
    display: none !important;
  }

  /* Mismo ancho que el home (lista de restaurantes). */
  .usuario-page {
    width: 100%;
    max-width: 1100px;
    padding: 0 0 100px;
    align-items: stretch;
    gap: 0;
  }

  .usuario-inner {
    align-items: stretch;
    gap: 16px;
    padding: 16px;
  }

  /* El detalle de un restaurante conserva el ancho de la página `restaurante`. */
  #usuario-detail-view {
    max-width: 760px;
    width: 100%;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .usuario-inner {
      padding: 16px 24px;
    }
  }

  #usuario-restaurants,
  #usuario-detail-dishes {
    align-items: stretch;
    gap: 8px;
  }

  .usuario-dishes-section {
    align-items: stretch;
    gap: 12px;
  }

  .usuario-dishes-title {
    font-size: 1rem;
    letter-spacing: 2px;
    color: var(--clr-text);
  }
</style>

<style is:global>
  /* ── Cinta superior (contenido generado/tocado por JS → scope global) ── */
  .usuario-ribbon {
    position: sticky;
    top: 80px;
    z-index: 90;
    justify-content: flex-start;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-bottom: solid 1px var(--clr-border);
  }

  @media (min-width: 768px) {
    .usuario-ribbon {
      top: 0;
    }
  }

  .u-ribbon-back {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    border-radius: 50%;
    color: var(--clr-primary);
    font-size: 1.1rem;
    cursor: pointer;
    padding: 0;
    transition: var(--transition);
  }

  .u-crumb {
    flex: 1;
    min-width: 0;
    justify-content: flex-start;
    align-items: center;
    gap: 6px;
    overflow: hidden;
  }

  .u-crumb-ic {
    color: var(--clr-primary);
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .u-crumb-user {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--clr-text);
    white-space: nowrap;
    flex-shrink: 0;
    max-width: 45%;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .u-crumb-sep {
    color: var(--clr-text);
    opacity: 0.4;
    flex-shrink: 0;
  }

  .u-crumb-loc {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--clr-primary);
    letter-spacing: 0.3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .u-friend-slot {
    flex-shrink: 0;
  }

  .u-friend-btn {
    flex-shrink: 0;
    gap: 5px;
    padding: 8px 13px;
    font-size: 0.72rem;
    letter-spacing: 0.4px;
    text-indent: 0;
    text-transform: none;
    border-radius: 50px;
    white-space: nowrap;
  }

  /* ── Botón "Agregar a los míos" (inyectado en header y platos clonados) ── */
  .u-add-btn {
    flex-shrink: 0;
    gap: 5px;
    padding: 8px 13px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-indent: 0;
    text-transform: none;
    border-radius: 50px;
    white-space: nowrap;
    cursor: pointer;
    border: solid 1.5px var(--clr-primary);
    background: var(--clr-primary);
    color: var(--clr-white);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
  }

  .u-add-btn:disabled {
    opacity: 0.6;
    cursor: default;
  }

  .u-add-btn.is-added {
    background: transparent;
    color: var(--clr-primary);
    border-color: var(--clr-border2);
  }

  .u-add-btn i {
    font-size: 0.8rem;
  }

  /* "Agregar" del header: abajo a la derecha y más pequeño */
  .u-header-actions {
    justify-content: flex-start;
    align-items: center;
  }

  .u-header-actions .u-add-btn {
    padding: 6px 12px;
    font-size: 0.68rem;
  }

  /* Variante compacta (solo icono) para las tarjetas de plato */
  .u-add-btn.u-add-icon {
    width: 40px;
    height: 40px;
    padding: 0;
    border-radius: 14px;
  }

  .u-add-btn.u-add-icon i {
    font-size: 1rem;
  }

  /* ── Marca "en tu lista" en la tarjeta de restaurante ── */
  .u-mine-check {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 4px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--clr-primary);
  }

  .u-mine-check i {
    font-size: 0.75rem;
  }

  @media (hover: hover) {
    .u-ribbon-back:hover {
      background: var(--clr-white2);
    }

    .u-add-btn:not(:disabled):hover {
      filter: brightness(1.06);
    }

    .u-add-btn.is-added:not(:disabled):hover {
      background: var(--clr-white2);
      filter: none;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";
  import { supabase } from "../lib/supabase.ts";
  import {
    initCache,
    getRestaurants,
    getDishesByRestaurant,
    getDishTypes,
    createRestaurant,
    createDish,
    createDishType,
    markAsVisited,
    adoptOfficialRestaurant,
    getOfficialRestaurantStat,
    getOfficialDishStat,
    type Restaurant,
    type Dish,
    type DishType,
  } from "../lib/data.ts";
  import {
    getPublicProfile,
    getUserRestaurants,
    getUserDishes,
    getUserDishTypes,
    getFriendStatus,
    sendFriendRequest,
    acceptRequest,
    deleteFriendship,
    restaurantAverage,
    type PublicUser,
    type FriendStatus,
  } from "../lib/social.ts";
  import { getRatingClass } from "../scripts/store.ts";

  // ─── Estado de módulo (persiste entre navegaciones ViewTransition) ──────────
  let profileUser: PublicUser | null = null;
  let restaurants: Restaurant[] = []; // del amigo
  let dishes: Dish[] = []; // del amigo
  let dishTypes: DishType[] = []; // del amigo
  let friend: { status: FriendStatus; friendshipId?: string } = { status: "none" };
  let currentDetailId: string | null = null;

  type SortField = "name" | "rating" | "date";
  type SortDir = "asc" | "desc";
  const SORT_KEY = "staurant_sort_user";

  function getSortState(): { field: SortField; dir: SortDir } {
    try {
      const saved = JSON.parse(localStorage.getItem(SORT_KEY) ?? "{}");
      return {
        field: (saved.field as SortField) ?? "rating",
        dir: (saved.dir as SortDir) ?? "desc",
      };
    } catch {
      return { field: "rating", dir: "desc" };
    }
  }
  let sortState = getSortState();

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function paintBadge(el: Element, rating: number | null): void {
    if (rating === null) {
      el.className = "rating-badge badge-empty";
      el.innerHTML = '<i class="bi bi-star-fill"></i>';
    } else {
      el.className = `rating-badge ${getRatingClass(rating)}`;
      el.innerHTML = `<span class="rating-num">${rating}</span>`;
    }
  }

  function fillName(el: HTMLElement, r: Restaurant): void {
    el.textContent = "";
    if (r.officialRestaurantId) {
      const idx = r.name.lastIndexOf(" ");
      const head = idx === -1 ? "" : r.name.slice(0, idx + 1);
      const tail = idx === -1 ? r.name : r.name.slice(idx + 1);
      if (head) el.appendChild(document.createTextNode(head));
      const tailSpan = document.createElement("span");
      tailSpan.className = "name-tail-nowrap";
      tailSpan.textContent = tail;
      const badge = document.createElement("i");
      badge.className = "bi bi-patch-check-fill verified-badge";
      badge.title = "Restaurante verificado";
      tailSpan.appendChild(badge);
      el.appendChild(tailSpan);
    } else {
      el.textContent = r.name;
    }
  }

  function buildGlobalRatingPill(avg: number, count: number): HTMLElement {
    const pill = document.createElement("span");
    pill.className = "global-rating-pill";
    pill.title = `Promedio global basado en ${count} ${count === 1 ? "calificación" : "calificaciones"}`;
    pill.innerHTML = `<i class="bi bi-globe2"></i> ${avg} <span class="grp-count">· ${count}</span>`;
    return pill;
  }

  // ─── "Ya lo tengo": cruce contra MI caché (getRestaurants/getDishes son míos) ──

  function myRestaurantFor(r: Restaurant): Restaurant | undefined {
    if (r.officialRestaurantId) {
      const m = getRestaurants().find(
        (x) => x.officialRestaurantId === r.officialRestaurantId,
      );
      if (m) return m;
    }
    const name = r.name.trim().toLowerCase();
    return getRestaurants().find((x) => x.name.trim().toLowerCase() === name);
  }

  function myDishFor(mine: Restaurant, d: Dish): Dish | undefined {
    const list = getDishesByRestaurant(mine.id);
    if (d.officialDishId) {
      const m = list.find((x) => x.officialDishId === d.officialDishId);
      if (m) return m;
    }
    const name = d.name.trim().toLowerCase();
    return list.find((x) => x.name.trim().toLowerCase() === name);
  }

  /** Traduce el typeId del amigo → un DishType MÍO (creándolo si hace falta). */
  function resolveMyType(friendTypeId: string | null): string | null {
    if (!friendTypeId) return null;
    const friendName = dishTypes.find((t) => t.id === friendTypeId)?.name;
    const upper = friendName?.trim().toUpperCase();
    if (!upper) return null;
    const existing = getDishTypes().find((t) => t.name === upper);
    return existing ? existing.id : createDishType(upper).id;
  }

  /** Asegura que el restaurante del amigo exista en MI lista; lo crea si no. */
  async function ensureMyRestaurant(r: Restaurant): Promise<Restaurant | null> {
    const existing = myRestaurantFor(r);
    if (existing) return existing;
    if (r.officialRestaurantId) {
      return await adoptOfficialRestaurant(r.officialRestaurantId);
    }
    return createRestaurant({ name: r.name, notes: "" });
  }

  async function addRestaurantToMine(r: Restaurant): Promise<void> {
    await ensureMyRestaurant(r); // queda en pendiente
  }

  async function addDishToMine(r: Restaurant, d: Dish): Promise<void> {
    const mine = await ensureMyRestaurant(r);
    if (!mine) return;
    if (!myDishFor(mine, d)) {
      createDish({
        restaurantId: mine.id,
        typeId: resolveMyType(d.typeId),
        name: d.name,
        rating: null, // yo aún no lo califico
        notes: d.notes,
      });
    }
    markAsVisited(mine.id); // agregar un plato → visitado
  }

  // ─── Cinta superior ─────────────────────────────────────────────────────────

  function renderRibbon(): void {
    const crumbEl = document.getElementById("usuario-crumb");
    const backEl = document.getElementById("usuario-back");
    const slot = document.getElementById("usuario-friend-slot");
    if (!crumbEl || !backEl || !slot || !profileUser) return;

    const who = profileUser.name?.trim() || profileUser.username || "Usuario";
    const detail = currentDetailId
      ? restaurants.find((r) => r.id === currentDetailId)
      : null;
    const loc = detail ? detail.name : "perfil";

    crumbEl.innerHTML = `<i class="bi bi-person-fill u-crumb-ic"></i>
      <span class="u-crumb-user">${escapeHtml(who)}</span>
      <span class="u-crumb-sep">·</span>
      <span class="u-crumb-loc">${escapeHtml(loc)}</span>`;

    backEl.onclick = () => {
      if (currentDetailId) setView(null);
      else navigate("/amigos");
    };

    slot.replaceChildren(buildFriendButton());
  }

  function buildFriendButton(): HTMLElement {
    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = "boton2 u-friend-btn flex-row";

    const refresh = async () => {
      friend = await getFriendStatus(profileUser!.id);
      renderRibbon();
    };

    switch (friend.status) {
      case "friends":
        btn.innerHTML = `<i class="bi bi-people-fill"></i> Amigos`;
        btn.onclick = () => {
          (window as any).confirmDialog?.show(
            "¿Eliminar de tus amigos?",
            async () => {
              if (friend.friendshipId) {
                btn.disabled = true;
                await deleteFriendship(friend.friendshipId);
                await refresh();
              }
            },
          );
        };
        break;
      case "outgoing":
        btn.innerHTML = `<i class="bi bi-clock-history"></i> Enviada`;
        btn.onclick = async () => {
          if (friend.friendshipId) {
            btn.disabled = true;
            await deleteFriendship(friend.friendshipId);
            await refresh();
          }
        };
        break;
      case "incoming":
        btn.className = "boton u-friend-btn flex-row";
        btn.innerHTML = `<i class="bi bi-check-lg"></i> Aceptar`;
        btn.onclick = async () => {
          if (friend.friendshipId) {
            btn.disabled = true;
            await acceptRequest(friend.friendshipId);
            await refresh();
          }
        };
        break;
      default:
        btn.className = "boton u-friend-btn flex-row";
        btn.innerHTML = `<i class="bi bi-person-plus"></i> Agregar`;
        btn.onclick = async () => {
          btn.disabled = true;
          await sendFriendRequest(profileUser!.id);
          await refresh();
        };
    }
    return btn;
  }

  // ─── Botón "Agregar a los míos" ───────────────────────────────────────────

  function buildAddButton(r: Restaurant, d?: Dish): HTMLButtonElement {
    const btn = document.createElement("button");
    btn.type = "button";
    const mine = myRestaurantFor(r);
    const isAdded = d ? !!(mine && myDishFor(mine, d)) : !!mine;

    btn.className = "u-add-btn flex-row" + (d ? " u-add-icon" : "");
    if (isAdded) btn.classList.add("is-added");

    if (d) {
      btn.innerHTML = isAdded
        ? '<i class="bi bi-check2"></i>'
        : '<i class="bi bi-plus-lg"></i>';
      btn.title = isAdded ? "Ya en tu lista" : "Agregar plato a los míos";
    } else {
      btn.innerHTML = isAdded
        ? '<i class="bi bi-check2"></i> En tu lista'
        : '<i class="bi bi-plus-lg"></i> Agregar';
    }

    btn.onclick = async (e) => {
      e.stopPropagation();
      if (isAdded) {
        if (mine) navigate(`/restaurante?id=${mine.id}`);
        return;
      }
      btn.disabled = true;
      try {
        if (d) await addDishToMine(r, d);
        else await addRestaurantToMine(r);
      } catch (err) {
        console.error("[usuario add]", err);
        btn.disabled = false;
        return;
      }
      // Re-render del detalle: recomputa el estado "en tu lista" de todos los botones.
      if (currentDetailId) renderDetail(currentDetailId);
    };
    return btn;
  }

  // ─── Lista de restaurantes ──────────────────────────────────────────────────

  function sortRestaurants(list: Restaurant[]): Restaurant[] {
    return [...list].sort((a, b) => {
      let cmp = 0;
      if (sortState.field === "name") {
        cmp = a.name.localeCompare(b.name);
      } else if (sortState.field === "rating") {
        const ra = restaurantAverage(dishes, a.id) ?? -1;
        const rb = restaurantAverage(dishes, b.id) ?? -1;
        cmp = ra - rb;
      } else {
        cmp = new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime();
      }
      return sortState.dir === "asc" ? cmp : -cmp;
    });
  }

  function buildRestaurantCard(r: Restaurant): Element {
    const tpl = document.getElementById(
      "tpl-user-restaurant-card",
    ) as HTMLTemplateElement;
    const article = (
      tpl.content.cloneNode(true) as DocumentFragment
    ).querySelector("article")!;

    article.removeAttribute("data-href");
    article.removeAttribute("style");
    article.classList.toggle("is-official", !!r.officialRestaurantId);

    fillName(article.querySelector("h3")!, r);

    const dishCount = dishes.filter((d) => d.restaurantId === r.id).length;
    const pill = article.querySelector(".dish-count-pill") as HTMLElement | null;
    if (pill) {
      pill.innerHTML = `<i class="bi bi-journal-text"></i> ${dishCount} ${dishCount === 1 ? "plato" : "platos"}`;
    }

    // Marca "en tu lista" si ya lo tengo
    if (myRestaurantFor(r)) {
      const body = article.querySelector(".card-body");
      if (body) {
        const chk = document.createElement("span");
        chk.className = "u-mine-check";
        chk.innerHTML = '<i class="bi bi-check-circle-fill"></i> En tu lista';
        body.appendChild(chk);
      }
    }

    paintBadge(article.querySelector(".rating-badge")!, restaurantAverage(dishes, r.id));

    article.addEventListener("click", () => openDetail(r.id));
    return article;
  }

  function renderList() {
    const listEl = document.getElementById("usuario-restaurants");
    const sortWrap = document.getElementById("usuario-sort-wrap");
    if (!listEl) return;

    if (sortWrap) sortWrap.hidden = restaurants.length < 2;

    if (restaurants.length === 0) {
      listEl.innerHTML = `<div class="empty-state flex-column">
           <i class="bi bi-journal-x"></i>
           <p>Este usuario aún no tiene restaurantes calificados.</p>
         </div>`;
      return;
    }

    const sorted = sortRestaurants(restaurants);
    listEl.innerHTML = "";
    const grid = document.createElement("div");
    grid.className = "cards-grid";
    sorted.forEach((r) => grid.appendChild(buildRestaurantCard(r)));
    listEl.appendChild(grid);
  }

  function updateSortUI() {
    document.querySelectorAll<HTMLButtonElement>(".sort-pill").forEach((btn) => {
      const isActive = btn.dataset.field === sortState.field;
      btn.classList.toggle("active", isActive);
      btn.querySelector("i")!.className = isActive
        ? `bi bi-arrow-${sortState.dir === "asc" ? "up" : "down"}`
        : "bi bi-arrow-down-up";
    });
  }

  // ─── Detalle de un restaurante ───────────────────────────────────────────────

  function buildDetailHeader(r: Restaurant): Element {
    const tpl = document.getElementById(
      "tpl-user-restaurant-header",
    ) as HTMLTemplateElement;
    const card = (tpl.content.cloneNode(true) as DocumentFragment).querySelector(
      ".rh-card",
    )!;
    card.removeAttribute("style");
    card.classList.toggle("is-official", !!r.officialRestaurantId);

    fillName(card.querySelector("h1")!, r);

    const list = dishes.filter((d) => d.restaurantId === r.id);
    const pill = card.querySelector(".dish-count-pill");
    if (pill) {
      pill.innerHTML = `<i class="bi bi-journal-text"></i> ${list.length} ${list.length === 1 ? "plato" : "platos"}`;
    }

    paintBadge(card.querySelector(".rating-badge")!, restaurantAverage(dishes, r.id));

    // Pill de rating global (si es oficial y hay agregados)
    if (r.officialRestaurantId) {
      const stat = getOfficialRestaurantStat(r.officialRestaurantId);
      if (stat && stat.ratingsCount > 0) {
        card.querySelector(".rh-pills")?.appendChild(
          buildGlobalRatingPill(stat.avgRating, stat.ratingsCount),
        );
      }
    }

    const notesEl = card.querySelector<HTMLElement>(".rh-notes");
    if (r.notes) notesEl!.textContent = r.notes;
    else notesEl?.remove();

    // Quitar el menú (editar/eliminar) y poner "Agregar a los míos" abajo a la derecha.
    card.querySelector(".rh-menu")?.remove();
    const footer = document.createElement("div");
    footer.className = "u-header-actions flex-row";
    footer.appendChild(buildAddButton(r));
    card.appendChild(footer);

    return card;
  }

  function buildDetailDishCard(r: Restaurant, d: Dish): Element {
    const tpl = document.getElementById(
      "tpl-user-dish-card",
    ) as HTMLTemplateElement;
    const article = (
      tpl.content.cloneNode(true) as DocumentFragment
    ).querySelector("article")!;
    article.removeAttribute("data-id");

    article.querySelector("h4")!.textContent = d.name;

    const typeTagEl = article.querySelector<HTMLElement>(".dish-type-tag");
    const typeName = d.typeId
      ? (dishTypes.find((t) => t.id === d.typeId)?.name ?? null)
      : null;
    if (typeName && typeTagEl) typeTagEl.textContent = typeName;
    else typeTagEl?.remove();

    // Pill global del plato (si es oficial y hay agregados)
    if (d.officialDishId) {
      const stat = getOfficialDishStat(d.officialDishId);
      if (stat && stat.ratingsCount > 0) {
        article
          .querySelector<HTMLElement>(".dish-info")
          ?.appendChild(buildGlobalRatingPill(stat.avgRating, stat.ratingsCount));
      }
    }

    const notesEl = article.querySelector<HTMLElement>(".dish-notes");
    if (d.notes) notesEl!.textContent = d.notes;
    else notesEl?.remove();

    paintBadge(article.querySelector(".rating-badge")!, d.rating);

    // Reemplazar el menú por "Agregar a los míos"
    const actions = article.querySelector(".dish-actions");
    if (actions) {
      actions.innerHTML = "";
      actions.appendChild(buildAddButton(r, d));
    }
    return article;
  }

  function renderDetail(restaurantId: string) {
    const restaurant = restaurants.find((r) => r.id === restaurantId);
    const headerEl = document.getElementById("usuario-detail-header");
    const listEl = document.getElementById("usuario-detail-dishes");
    if (!restaurant || !headerEl || !listEl) return;

    headerEl.replaceChildren(buildDetailHeader(restaurant));

    const list = dishes
      .filter((d) => d.restaurantId === restaurant.id)
      .sort((a, b) => (b.rating ?? -1) - (a.rating ?? -1));

    if (list.length === 0) {
      listEl.innerHTML = `<div class="empty-state flex-column">
           <i class="bi bi-egg-fried"></i>
           <p>Este restaurante no tiene platos.</p>
         </div>`;
      return;
    }

    listEl.innerHTML = "";
    list.forEach((d) => listEl.appendChild(buildDetailDishCard(restaurant, d)));
  }

  // ─── Cambio de vista (lista ↔ detalle) vía query param ?r= ──────────────────

  function setView(restaurantId: string | null) {
    const listView = document.getElementById("usuario-list-view");
    const detailView = document.getElementById("usuario-detail-view");
    if (!listView || !detailView) return;

    const userId = new URLSearchParams(window.location.search).get("id") ?? "";
    if (restaurantId && restaurants.some((r) => r.id === restaurantId)) {
      currentDetailId = restaurantId;
      listView.hidden = true;
      detailView.hidden = false;
      renderDetail(restaurantId);
    } else {
      currentDetailId = null;
      listView.hidden = false;
      detailView.hidden = true;
      renderList();
      updateSortUI();
    }
    renderRibbon();

    // Mantener la URL en sync (sin recargar) para back-button intuitivo.
    const target = restaurantId
      ? `/usuario?id=${userId}&r=${restaurantId}`
      : `/usuario?id=${userId}`;
    if (window.location.pathname + window.location.search !== target) {
      history.replaceState(null, "", target);
    }
  }

  function openDetail(restaurantId: string) {
    setView(restaurantId);
    window.scrollTo({ top: 0 });
  }

  // ─── Init ───────────────────────────────────────────────────────────────────

  document.addEventListener("astro:page-load", async () => {
    const ribbonEl = document.getElementById("usuario-ribbon");
    if (!ribbonEl) return;

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = "/login";
      return;
    }

    const userId = new URLSearchParams(window.location.search).get("id") ?? "";
    if (!userId) {
      navigate("/amigos");
      return;
    }
    if (userId === session.user.id) {
      // Tu propio perfil → usar la página de perfil personal.
      navigate("/perfil");
      return;
    }

    await initCache(session.user.id);

    // Skeleton mientras carga
    const restEl = document.getElementById("usuario-restaurants");
    if (restEl && (!profileUser || profileUser.id !== userId)) {
      const grid = document.createElement("div");
      grid.className = "cards-grid";
      for (let i = 0; i < 3; i++) {
        const sk = document.createElement("div");
        sk.className = "skeleton-card";
        grid.appendChild(sk);
      }
      restEl.replaceChildren(grid);
    }

    const [user, rs, ds, dts, fr] = await Promise.all([
      getPublicProfile(userId),
      getUserRestaurants(userId),
      getUserDishes(userId),
      getUserDishTypes(userId),
      getFriendStatus(userId),
    ]);

    if (!user) {
      const crumbEl = document.getElementById("usuario-crumb");
      if (crumbEl) {
        crumbEl.innerHTML = `<span class="u-crumb-loc">Usuario no encontrado</span>`;
      }
      const listEl = document.getElementById("usuario-restaurants");
      if (listEl) {
        listEl.innerHTML = `<div class="empty-state flex-column">
             <i class="bi bi-person-x"></i>
             <p>No se encontró este usuario.</p>
           </div>`;
      }
      return;
    }

    profileUser = user;
    restaurants = rs;
    dishes = ds;
    dishTypes = dts;
    friend = fr;

    document.title = `${user.name || "Perfil"} · STAURANT`;

    // Wire sort pills
    document.querySelectorAll<HTMLButtonElement>(".sort-pill").forEach((btn) => {
      btn.onclick = () => {
        const field = btn.dataset.field as SortField;
        if (sortState.field === field) {
          sortState.dir = sortState.dir === "asc" ? "desc" : "asc";
        } else {
          sortState.field = field;
          sortState.dir = field === "name" ? "asc" : "desc";
        }
        localStorage.setItem(SORT_KEY, JSON.stringify(sortState));
        updateSortUI();
        renderList();
      };
    });

    const r = new URLSearchParams(window.location.search).get("r");
    setView(r);
  });
</script>
