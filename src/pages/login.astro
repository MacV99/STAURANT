---
import Layout1 from "../layouts/Layout1.astro";
---

<Layout1 title="Acceder · STAURANT" bare>
  <div class="auth-page flex-row">
    <div class="auth-card flex-column">
      <!-- Logo -->
      <div class="auth-logo flex-row">
        <a href="/"><img src="/img/logo2.png" alt="STAURANT" /></a>
      </div>

      <!-- Tabs -->
      <div class="auth-tabs">
        <button class="auth-tab active" data-tab="login">Iniciar sesión</button>
        <button class="auth-tab" data-tab="register">Registrarse</button>
      </div>

      <!-- Error global -->
      <p id="auth-error" class="auth-error" aria-live="polite"></p>

      <!-- Form login -->
      <form id="form-login" class="flex-column" novalidate>
        <label>
          <span class="field-label">Email</span>
          <input
            type="email"
            id="login-email"
            autocomplete="email"
            placeholder="tu@email.com"
            required
          />
        </label>
        <label>
          <span class="field-label">Contraseña</span>
          <div class="pw-wrapper">
            <input
              type="password"
              id="login-password"
              autocomplete="current-password"
              placeholder="••••••••"
              required
            />
            <button
              type="button"
              class="pw-toggle"
              id="toggle-login-pw"
              aria-label="Mostrar contraseña"
            >
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </label>
        <button type="submit" class="btn-primary" id="btn-login">Entrar</button>
      </form>

      <!-- Continuar con Google (compartido entre login y register) -->
      <div class="social-section flex-column">
        <div class="auth-divider flex-row"><span>o</span></div>
        <button id="btn-google" class="btn-google" type="button">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continuar con Google
        </button>
      </div>

      <!-- Form register -->
      <form id="form-register" class="flex-column" novalidate>
        <label>
          <span class="field-label">Nombre</span>
          <input
            type="text"
            id="reg-name"
            autocomplete="name"
            placeholder="Tu nombre"
          />
        </label>
        <label>
          <span class="field-label">Email</span>
          <input
            type="email"
            id="reg-email"
            autocomplete="email"
            placeholder="tu@email.com"
            required
          />
        </label>
        <label>
          <span class="field-label"
            >Contraseña <span class="field-hint">(mín. 6 caracteres)</span
            ></span
          >
          <div class="pw-wrapper">
            <input
              type="password"
              id="reg-password"
              autocomplete="new-password"
              placeholder="••••••••"
              required
            />
            <button
              type="button"
              class="pw-toggle"
              id="toggle-reg-pw"
              aria-label="Mostrar contraseña"
            >
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </label>
        <button type="submit" class="btn-primary" id="btn-register"
          >Crear cuenta</button
        >
      </form>
    </div>
  </div>
</Layout1>

<style>
  .auth-page {
    width: 100%;
    min-height: 100dvh;
    padding: 24px 16px;
  }

  .auth-card {
    background: var(--clr-white);
    border: 1px solid var(--clr-border);
    border-radius: 20px;
    padding: 32px 24px;
    width: 100%;
    max-width: 400px;
    align-items: stretch;
    gap: 20px;
  }

  .auth-logo img {
    height: 52px;
    width: auto;
    border-radius: 10px;
  }

  .auth-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--clr-white2);
    border-radius: 12px;
    padding: 4px;
    gap: 4px;
  }

  .auth-tab {
    padding: 9px;
    border-radius: 9px;
    border: none;
    background: transparent;
    color: var(--clr-text);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-transform: none;
    cursor: pointer;
    transition: var(--transition);
  }

  .auth-tab.active {
    background: var(--clr-white);
    color: var(--clr-primary);
  }

  /* Oculto por defecto antes de que corra el JS */
  #form-register {
    display: none;
  }

  @keyframes formIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  form {
    align-items: stretch;
    gap: 14px;
  }

  form.form-visible {
    animation: formIn 0.22s ease both;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .field-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.8px;
    color: var(--clr-dark2);
    text-transform: uppercase;
  }

  .field-hint {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--clr-text);
    opacity: 0.6;
    font-size: 0.75rem;
  }

  label input {
    border-radius: var(--border-radius);
    width: 100%;
  }

  /* Password toggle */
  .pw-wrapper {
    position: relative;
    display: flex;
  }

  .pw-wrapper input {
    flex: 1;
    padding-right: 44px;
    border-radius: var(--border-radius);
  }

  .pw-toggle {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    width: 42px;
    background: transparent;
    border: none;
    color: var(--clr-text);
    opacity: 0.45;
    font-size: 0.95rem;
    letter-spacing: 0;
    text-transform: none;
    padding: 0;
    border-radius: 0 var(--border-radius) var(--border-radius) 0;
    cursor: pointer;
    transition: opacity 0.12s ease;
  }

  .auth-error {
    font-size: 0.85rem;
    color: #c0392b;
    min-height: 1.2em;
    text-align: center;
  }

  /* ── Google OAuth ── */

  .social-section {
    align-items: stretch;
    gap: 14px;
  }

  .auth-divider {
    gap: 10px;
    color: var(--clr-text);
    font-size: 0.78rem;
    opacity: 0.4;
  }

  .auth-divider::before,
  .auth-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--clr-border);
  }

  .btn-google {
    gap: 10px;
    width: 100%;
    background: #fff;
    border: 1.5px solid var(--clr-border);
    border-radius: 12px;
    padding: 11px 16px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--clr-text);
    cursor: pointer;
    letter-spacing: 0.3px;
    text-transform: none;
    transition: var(--transition);
  }

  .btn-google svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .btn-google:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .btn-primary {
    width: 100%;
    background: var(--clr-primary);
    color: var(--clr-white);
    border-color: var(--clr-primary);
    font-size: 0.9rem;
    padding: 12px;
    border-radius: 12px;
    margin-top: 4px;
    letter-spacing: 1px;
  }

  @media (hover: hover) {
    .btn-google:not(:disabled):hover {
      background: var(--clr-white2);
      border-color: #bbb;
    }

    .pw-toggle:hover {
      opacity: 0.85;
    }

    .btn-primary:hover {
      background: var(--clr-primary-dark);
      border-color: var(--clr-primary-dark);
    }

    .auth-tab:not(.active):hover {
      color: var(--clr-primary);
    }
  }

  @media (min-width: 768px) {
    .auth-card {
      padding: 40px 36px;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";
  import { supabase } from "../lib/supabase.ts";

  // Si ya hay sesión, ir directo al inicio
  const {
    data: { session },
  } = await supabase.auth.getSession();
  if (session) {
    window.location.href = "/";
  }

  // ─── Tabs ──────────────────────────────────────────────────────────────────

  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".auth-tab");
  const formLogin = document.getElementById("form-login") as HTMLFormElement;
  const formRegister = document.getElementById(
    "form-register",
  ) as HTMLFormElement;
  const errorEl = document.getElementById("auth-error")!;

  function showTab(tab: "login" | "register") {
    const active = tab === "login" ? formLogin : formRegister;
    const inactive = tab === "login" ? formRegister : formLogin;

    inactive.style.display = "none";
    inactive.classList.remove("form-visible");

    active.style.display = "flex";
    active.classList.remove("form-visible");
    void active.offsetHeight;
    active.classList.add("form-visible");

    tabBtns.forEach((btn) =>
      btn.classList.toggle("active", btn.dataset.tab === tab),
    );
    errorEl.textContent = "";
  }

  showTab("login");

  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () =>
      showTab(btn.dataset.tab as "login" | "register"),
    );
  });

  // ─── Password toggles ──────────────────────────────────────────────────────

  function setupPwToggle(inputId: string, btnId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement;
    const btn = document.getElementById(btnId) as HTMLButtonElement;
    btn.addEventListener("click", () => {
      const isHidden = input.type === "password";
      input.type = isHidden ? "text" : "password";
      btn.querySelector("i")!.className = isHidden
        ? "bi bi-eye-slash"
        : "bi bi-eye";
    });
  }

  setupPwToggle("login-password", "toggle-login-pw");
  setupPwToggle("reg-password", "toggle-reg-pw");

  // ─── Google OAuth ───────────────────────────────────────────────────────────

  const btnGoogle = document.getElementById("btn-google") as HTMLButtonElement;
  btnGoogle.addEventListener("click", async () => {
    btnGoogle.disabled = true;
    btnGoogle.textContent = "Redirigiendo...";
    errorEl.textContent = "";

    const { error } = await supabase.auth.signInWithOAuth({
      provider: "google",
      options: {
        redirectTo: `${window.location.origin}/auth/callback`,
      },
    });

    if (error) {
      errorEl.textContent = "No se pudo conectar con Google. Intenta de nuevo.";
      btnGoogle.disabled = false;
      btnGoogle.innerHTML = `<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="width:18px;height:18px;flex-shrink:0"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>Continuar con Google`;
    }
    // Si no hay error: el browser navega a Google, no necesitamos hacer nada más
  });

  // ─── Login ─────────────────────────────────────────────────────────────────

  formLogin.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.textContent = "";
    const email = (
      document.getElementById("login-email") as HTMLInputElement
    ).value.trim();
    const password = (
      document.getElementById("login-password") as HTMLInputElement
    ).value;
    const btn = document.getElementById("btn-login") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Entrando...";

    const { error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });
    if (error) {
      const msg = error.message.toLowerCase();
      errorEl.textContent = msg.includes("invalid login credentials")
        ? "Email o contraseña incorrectos."
        : msg.includes("email not confirmed")
          ? "Debes confirmar tu email antes de entrar. Revisa tu bandeja de entrada."
          : msg.includes("too many requests")
            ? "Demasiados intentos. Espera unos minutos."
            : "Error al iniciar sesión. Intenta de nuevo.";
      btn.disabled = false;
      btn.textContent = "Entrar";
      return;
    }
    navigate("/");
  });

  // ─── Register ──────────────────────────────────────────────────────────────

  formRegister.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.textContent = "";
    const name = (
      document.getElementById("reg-name") as HTMLInputElement
    ).value.trim();
    const email = (
      document.getElementById("reg-email") as HTMLInputElement
    ).value.trim();
    const password = (
      document.getElementById("reg-password") as HTMLInputElement
    ).value;
    const btn = document.getElementById("btn-register") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Creando cuenta...";

    const { error } = await supabase.auth.signUp({
      email,
      password,
      options: { data: { full_name: name } },
    });
    if (error) {
      const msg = error.message.toLowerCase();
      errorEl.textContent =
        msg.includes("already registered") || msg.includes("user already")
          ? "Ya existe una cuenta con ese email."
          : msg.includes("password")
            ? "La contraseña debe tener al menos 6 caracteres."
            : msg.includes("invalid email")
              ? "El formato del email no es válido."
              : "Error al crear la cuenta. Intenta de nuevo.";
      btn.disabled = false;
      btn.textContent = "Crear cuenta";
      return;
    }
    navigate("/");
  });
</script>
