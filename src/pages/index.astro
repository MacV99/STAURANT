---
import Layout1 from "../layouts/Layout1.astro";
import TabBar from "../components/TabBar.astro";
import SortBar from "../components/SortBar.astro";
import RestaurantForm from "../components/RestaurantForm.astro";
import ConfirmDialog from "../components/ConfirmDialog.astro";
import RestaurantCard from "../components/RestaurantCard.astro";
import type { Restaurant } from "../lib/data";

const tplRestaurant: Restaurant = {
  id: "",
  name: "",
  status: "visited",
  notes: "",
  createdAt: "",
  updatedAt: "",
  officialRestaurantId: null,
};
---

<Layout1 title="STAURANT">
  <div class="app-page flex-column">
    <div class="page-top-sticky texture-dotted flex-column">
      <TabBar />

      <div class="search-wrap">
        <i class="bi bi-search-fill search-icon"></i>
        <input
          id="restaurant-search"
          class="search-input"
          type="search"
          placeholder="Buscar por nombre, notas o platos..."
          autocomplete="off"
          spellcheck="false"
        />
        <button
          id="restaurant-search-clear"
          class="search-clear"
          type="button"
          aria-label="Limpiar búsqueda"
          hidden
        >
          <i class="bi bi-x-circle-fill"></i>
        </button>
      </div>

      <SortBar
        pills={[
          { field: "modified", label: "Modificación" },
          { field: "date", label: "Creación" },
          { field: "name", label: "Nombre" },
          { field: "rating", label: "Rating" },
        ]}
      />
    </div>

    <div id="tab-visitados" class="tab-content" role="tabpanel" hidden></div>
    <div id="tab-pendientes" class="tab-content" role="tabpanel" hidden></div>
  </div>

  <RestaurantForm />
  <ConfirmDialog />

  <!-- Template renderizado por Astro en build time; el JS cliente lo clona para cada tarjeta -->
  <template id="tpl-restaurant-card">
    <RestaurantCard restaurant={tplRestaurant} avg={null} dishCount={0} />
  </template>
</Layout1>

<style>
  .app-page {
    align-items: stretch;
    justify-content: flex-start;
    width: 100%;
    max-width: 1100px;
    padding: 0 0 24px;
    gap: 0;
  }

  .page-top-sticky {
    position: sticky;
    top: 80px;
    z-index: 90;
    padding: 12px 16px;
    align-items: stretch;
    justify-content: flex-start;
    gap: 12px;
    border-bottom: solid 1px var(--clr-border);
  }

  @media (min-width: 768px) {
    .page-top-sticky {
      top: 0;
      padding: 20px 16px 8px;
    }
  }

  .tab-content {
    width: 100%;
    padding: 16px 16px 0;
  }

  .search-wrap {
    position: relative;
    width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--clr-text);
    opacity: 0.45;
    font-size: 0.95rem;
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 11px 16px 11px 38px;
    border-radius: var(--border-radius);
    border: 1.5px solid var(--clr-border);
    background: var(--clr-white);
    font-size: 0.9rem;
    color: var(--clr-text);
    transition: border-color var(--transition);
  }

  .search-input::placeholder {
    color: var(--clr-text);
    opacity: 0.5;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--clr-border2);
  }

  /* ocultar el botón nativo de limpiar en Chrome/Safari */
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .search-input:not(:placeholder-shown) {
    padding-right: 38px;
  }

  .search-clear {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    padding: 6px;
    color: var(--clr-text);
    opacity: 0.55;
    cursor: pointer;
    font-size: 1.05rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: opacity var(--transition);
  }

  .search-clear[hidden] {
    display: none;
  }

  @media (hover: hover) {
    .search-clear:hover {
      opacity: 1;
    }
  }

  @media (min-width: 768px) {
    .app-page {
      padding: 0 24px 100px;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";
  import { supabase } from "../lib/supabase.ts";
  import {
    initCache,
    isCacheLoaded,
    getRestaurants,
    getDishesByRestaurant,
    getRestaurantAverage,
    hasUnratedDishes,
    type Restaurant,
  } from "../lib/data.ts";
  import { getRatingClass } from "../scripts/store.ts";

  // ─── Sort state (persiste entre navegaciones en memoria de módulo) ──────────

  type SortField = "name" | "rating" | "date" | "modified";
  type SortDir = "asc" | "desc";
  const SORT_KEY = "staurant_sort_r";

  function getSortState(): { field: SortField; dir: SortDir } {
    try {
      const saved = JSON.parse(localStorage.getItem(SORT_KEY) ?? "{}");
      return {
        field: (saved.field as SortField) ?? "modified",
        dir: (saved.dir as SortDir) ?? "desc",
      };
    } catch {
      return { field: "modified", dir: "desc" };
    }
  }
  function setSortState(s: { field: SortField; dir: SortDir }) {
    localStorage.setItem(SORT_KEY, JSON.stringify(s));
  }

  let sortState = getSortState();

  // ─── Search state ─────────────────────────────────────────────────────────
  let searchQuery = "";

  function sortRestaurants(list: ReturnType<typeof getRestaurants>) {
    return [...list].sort((a, b) => {
      let cmp = 0;
      if (sortState.field === "name") {
        cmp = a.name.localeCompare(b.name);
      } else if (sortState.field === "rating") {
        const ra = getRestaurantAverage(a.id) ?? -1;
        const rb = getRestaurantAverage(b.id) ?? -1;
        cmp = ra - rb;
      } else if (sortState.field === "modified") {
        cmp = new Date(a.updatedAt).getTime() - new Date(b.updatedAt).getTime();
      } else {
        cmp = new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime();
      }
      return sortState.dir === "asc" ? cmp : -cmp;
    });
  }

  function getActiveTab(): "visitados" | "pendientes" {
    return (
      (new URLSearchParams(window.location.search).get("tab") as
        | "visitados"
        | "pendientes") ?? "visitados"
    );
  }

  // ─── Sort UI ──────────────────────────────────────────────────────────────

  function updateSortUI() {
    document
      .querySelectorAll<HTMLButtonElement>(".sort-pill")
      .forEach((btn) => {
        const isActive = btn.dataset.field === sortState.field;
        btn.classList.toggle("active", isActive);
        btn.querySelector("i")!.className = isActive
          ? `bi bi-arrow-${sortState.dir === "asc" ? "up" : "down"}`
          : "bi bi-arrow-down-up";
      });
  }

  // ─── Construye un elemento <article> clonando el template del componente ────

  function buildRestaurantCardElement(
    r: Restaurant,
    avg: number | null,
    dishCount: number,
  ): Element {
    const tpl = document.getElementById(
      "tpl-restaurant-card",
    ) as HTMLTemplateElement;
    const article = (
      tpl.content.cloneNode(true) as DocumentFragment
    ).querySelector("article")!;

    article.setAttribute("data-href", `/restaurante?id=${r.id}`);
    article.setAttribute("style", `view-transition-name: restaurant-${r.id}`);
    const h3 = article.querySelector("h3")!;
    h3.textContent = r.name;
    if (r.officialRestaurantId) {
      const badge = document.createElement("i");
      badge.className = "bi bi-patch-check-fill verified-badge";
      badge.title = "Restaurante verificado";
      h3.appendChild(document.createTextNode(" "));
      h3.appendChild(badge);
    }

    const pill = article.querySelector(".dish-count-pill");
    if (pill) {
      pill.innerHTML = `<i class="bi bi-journal-text"></i> ${dishCount} ${dishCount === 1 ? "plato" : "platos"}`;
      if (hasUnratedDishes(r.id)) {
        const dot = document.createElement("span");
        dot.className = "unrated-dot";
        dot.title = "Hay platos sin calificar";
        pill.appendChild(dot);
      }
    }

    const badge = article.querySelector(".rating-badge")!;
    if (avg === null) {
      badge.className = "rating-badge badge-empty";
      badge.innerHTML = '<i class="bi bi-star"></i>';
    } else {
      badge.className = `rating-badge ${getRatingClass(avg)}`;
      badge.innerHTML = `<span class="rating-num">${avg}</span>`;
    }

    return article;
  }

  // ─── Render ───────────────────────────────────────────────────────────────

  function renderList(status: "visited" | "pending", container: HTMLElement) {
    const q = searchQuery.toLowerCase().trim();
    const all = getRestaurants().filter((r) => {
      if (r.status !== status) return false;
      if (!q) return true;
      if (
        r.name.toLowerCase().includes(q) ||
        r.notes.toLowerCase().includes(q)
      ) {
        return true;
      }
      return getDishesByRestaurant(r.id).some(
        (d) =>
          d.name.toLowerCase().includes(q) ||
          d.notes.toLowerCase().includes(q),
      );
    });
    const sorted = sortRestaurants(all);

    if (sorted.length === 0) {
      container.innerHTML = q
        ? `<div class="empty-state flex-column">
             <i class="bi bi-search"></i>
             <p>Sin resultados para "<strong>${q}</strong>".</p>
           </div>`
        : `<div class="empty-state flex-column">
             <i class="bi bi-${status === "visited" ? "journal-check" : "bookmark"}"></i>
             <p>${status === "visited" ? "Aún no has registrado restaurantes visitados." : "No tienes restaurantes pendientes."}</p>
             ${status === "visited" ? '<p class="empty-hint">Agrega uno con el botón <strong>+</strong></p>' : ""}
           </div>`;
      return;
    }

    container.innerHTML = "";
    const grid = document.createElement("div");
    grid.className = "cards-grid";
    sorted.forEach((r) => {
      const card = buildRestaurantCardElement(
        r,
        getRestaurantAverage(r.id),
        getDishesByRestaurant(r.id).length,
      );
      card.addEventListener("click", () => navigate(`/restaurante?id=${r.id}`));
      grid.appendChild(card);
    });
    container.appendChild(grid);
  }

  function updateCounts() {
    const all = getRestaurants();
    const cv = document.getElementById("count-visitados");
    const cp = document.getElementById("count-pendientes");
    if (cv)
      cv.textContent = String(all.filter((r) => r.status === "visited").length);
    if (cp)
      cp.textContent = String(all.filter((r) => r.status === "pending").length);
  }

  function updateSortBarVisibility() {
    const sortBarEl = document.querySelector<HTMLElement>(".sort-bar");
    if (!sortBarEl) return;
    const isVisitados = getActiveTab() === "visitados";
    const status = isVisitados ? "visited" : "pending";
    sortBarEl.hidden =
      getRestaurants().filter((r) => r.status === status).length < 2;

    // El pill de rating no aplica a pendientes (no tienen calificación).
    // Usamos style.display en vez de hidden para evitar que el display:inline-flex
    // del CSS de SortBar.astro sobrescriba el display:none del atributo hidden.
    const ratingPill = sortBarEl.querySelector<HTMLElement>(
      '[data-field="rating"]',
    );
    if (ratingPill) ratingPill.style.display = isVisitados ? "" : "none";
  }

  function renderBoth() {
    const tv = document.getElementById("tab-visitados") as HTMLElement | null;
    const tp = document.getElementById("tab-pendientes") as HTMLElement | null;
    if (!tv || !tp) return;
    renderList("visited", tv);
    renderList("pending", tp);
    updateCounts();
    updateSortBarVisibility();
  }

  function activateTab(tab: "visitados" | "pendientes") {
    const tv = document.getElementById("tab-visitados") as HTMLElement | null;
    const tp = document.getElementById("tab-pendientes") as HTMLElement | null;
    if (!tv || !tp) return;
    tv.hidden = tab !== "visitados";
    tp.hidden = tab !== "pendientes";
    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
      const active = btn.dataset.tab === tab;
      btn.classList.toggle("active", active);
      btn.setAttribute("aria-selected", String(active));
    });
    history.replaceState(null, "", `/?tab=${tab}`);
    updateSortBarVisibility();
  }

  // ─── Listeners permanentes a nivel de módulo ──────────────────────────────

  document.addEventListener("restaurant:created", () => {
    renderBoth();
    activateTab("pendientes");
  });
  document.addEventListener("restaurant:updated", () => renderBoth());
  document.addEventListener("restaurant:visited", () => renderBoth());
  document.addEventListener("cache:synced", () => renderBoth());

  // ─── PRE-RENDER en astro:after-swap ─────────────────────────────────────────

  document.addEventListener("astro:after-swap", () => {
    const tabVisitadosEl = document.getElementById(
      "tab-visitados",
    ) as HTMLElement | null;
    const tabPendientesEl = document.getElementById(
      "tab-pendientes",
    ) as HTMLElement | null;
    if (!tabVisitadosEl || !isCacheLoaded()) return;

    const activeTab = getActiveTab();

    renderList("visited", tabVisitadosEl);
    if (tabPendientesEl) renderList("pending", tabPendientesEl);

    tabVisitadosEl.hidden = activeTab !== "visitados";
    if (tabPendientesEl) tabPendientesEl.hidden = activeTab !== "pendientes";

    const sortBarEl = document.querySelector<HTMLElement>(".sort-bar");
    if (sortBarEl) {
      const status = activeTab === "visitados" ? "visited" : "pending";
      sortBarEl.hidden =
        getRestaurants().filter((r) => r.status === status).length < 2;
    }

    const all = getRestaurants();
    const cv = document.getElementById("count-visitados");
    const cp = document.getElementById("count-pendientes");
    if (cv)
      cv.textContent = String(all.filter((r) => r.status === "visited").length);
    if (cp)
      cp.textContent = String(all.filter((r) => r.status === "pending").length);

    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
      const active = btn.dataset.tab === activeTab;
      btn.classList.toggle("active", active);
      btn.setAttribute("aria-selected", String(active));
    });

    updateSortUI();
  });

  // ─── Init por cada navegación (ViewTransitions + carga directa) ─────────────

  document.addEventListener("astro:page-load", async () => {
    const tabVisitadosEl = document.getElementById("tab-visitados");
    if (!tabVisitadosEl) return;

    const {
      data: { session },
    } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = "/login";
      return;
    }

    // Inject skeleton cards while cache loads (first visit only)
    if (!isCacheLoaded()) {
      const activeTab = getActiveTab();
      const skeletonGrid = () => {
        const grid = document.createElement("div");
        grid.className = "cards-grid";
        for (let i = 0; i < 4; i++) {
          const sk = document.createElement("div");
          sk.className = "skeleton-card";
          grid.appendChild(sk);
        }
        return grid;
      };
      const tv = document.getElementById("tab-visitados") as HTMLElement | null;
      const tp = document.getElementById("tab-pendientes") as HTMLElement | null;
      if (tv) { tv.innerHTML = ""; tv.appendChild(skeletonGrid()); tv.hidden = activeTab !== "visitados"; }
      if (tp) { tp.innerHTML = ""; tp.appendChild(skeletonGrid()); tp.hidden = activeTab !== "pendientes"; }
    }

    await initCache(session.user.id);

    document
      .querySelectorAll<HTMLButtonElement>(".sort-pill")
      .forEach((btn) => {
        btn.onclick = () => {
          const field = btn.dataset.field as SortField;
          if (sortState.field === field) {
            sortState.dir = sortState.dir === "asc" ? "desc" : "asc";
          } else {
            sortState.field = field;
            sortState.dir = field === "name" ? "asc" : "desc";
          }
          setSortState(sortState);
          updateSortUI();
          renderBoth();
        };
      });

    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
      btn.onclick = () =>
        activateTab(btn.dataset.tab as "visitados" | "pendientes");
    });

    const searchEl = document.getElementById(
      "restaurant-search",
    ) as HTMLInputElement | null;
    const clearEl = document.getElementById(
      "restaurant-search-clear",
    ) as HTMLButtonElement | null;
    const syncClear = () => {
      if (clearEl) clearEl.hidden = searchQuery.length === 0;
    };
    if (searchEl) {
      searchEl.value = searchQuery;
      syncClear();
      searchEl.oninput = () => {
        searchQuery = searchEl.value;
        syncClear();
        renderBoth();
      };
    }
    if (clearEl) {
      clearEl.onclick = () => {
        searchQuery = "";
        if (searchEl) {
          searchEl.value = "";
          searchEl.focus();
        }
        syncClear();
        renderBoth();
      };
    }

    updateSortUI();
    renderBoth();
    activateTab(getActiveTab());
  });
</script>
