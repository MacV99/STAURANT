---
import Layout1 from "../layouts/Layout1.astro";
---

<Layout1 title="Perfil · STAURANT">
  <div class="profile-page">
    <a href="/" class="back-link">
      <i class="bi bi-arrow-left"></i> Volver
    </a>

    <!-- Perfil -->
    <div class="profile-card">
      <div class="profile-avatar" id="profile-avatar">
        <i class="bi bi-person-fill"></i>
      </div>

      <div class="profile-email-block">
        <span class="field-label">Email</span>
        <p id="profile-email" class="profile-email">—</p>
      </div>

      <form id="profile-form" novalidate>
        <label for="profile-name">
          <span class="field-label">Nombre</span>
          <input
            type="text"
            id="profile-name"
            autocomplete="name"
            placeholder="Tu nombre"
          />
        </label>
        <p id="profile-msg" class="profile-msg" aria-live="polite"></p>
        <button type="submit" class="btn-primary">Guardar cambios</button>
      </form>

      <div class="profile-divider"></div>

      <button id="btn-logout" class="btn-danger-outline">
        <i class="bi bi-box-arrow-right"></i> Cerrar sesión
      </button>
    </div>

    <!-- Columna derecha: stats + top 3 -->
    <div class="dash-col">
      <div class="dash-card">
        <h2 class="dash-title">
          <i class="bi bi-bar-chart-fill"></i> Tu actividad
        </h2>
        <div class="stats-grid">
          <div class="stat-cell">
            <span class="stat-number" id="sn-total">—</span>
            <span class="stat-label">Total</span>
          </div>
          <div class="stat-cell">
            <span class="stat-number accent-green" id="sn-visited">—</span>
            <span class="stat-label">Visitados</span>
          </div>
          <div class="stat-cell">
            <span class="stat-number accent-muted" id="sn-pending">—</span>
            <span class="stat-label">Pendientes</span>
          </div>
          <div class="stat-cell">
            <span class="stat-number" id="sn-dishes">—</span>
            <span class="stat-label">Platos</span>
          </div>
          <div class="stat-cell">
            <span class="stat-number" id="sn-avg">—</span>
            <span class="stat-label">Promedio</span>
          </div>
          <div class="stat-cell">
            <span class="stat-number accent-green" id="sn-rated">—</span>
            <span class="stat-label">Calificados</span>
          </div>
        </div>
      </div>

      <div class="dash-card">
        <h2 class="dash-title">
          <i class="bi bi-trophy-fill"></i> Top 3 favoritos
        </h2>
        <div id="top3-list" class="top3-list">
          <p class="top3-empty">Añade platos para ver tus favoritos</p>
        </div>
      </div>
    </div>
  </div>
</Layout1>

<style>
  .profile-page {
    width: 100%;
    max-width: 480px;
    padding: 20px 16px 80px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Columna derecha en desktop ── */
  .dash-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--clr-primary);
    letter-spacing: 1px;
    width: fit-content;
    padding: 6px 0;
    transition: var(--transition);
  }

  /* ── Cards ── */

  .profile-card,
  .dash-card {
    background: var(--clr-white);
    border: solid 1px var(--clr-border);
    border-radius: 20px;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Profile card internals ── */

  .profile-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--clr-white2);
    border: solid 2px var(--clr-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--clr-primary);
    align-self: center;
  }

  .profile-email-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .field-label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-dark2);
    text-transform: uppercase;
  }

  .profile-email {
    font-size: 0.95rem;
    color: var(--clr-text);
    word-break: break-all;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  label input {
    border-radius: var(--border-radius);
    width: 100%;
  }

  .profile-msg {
    font-size: 0.85rem;
    min-height: 1.2em;
    color: var(--clr-primary);
    font-weight: 600;
  }

  .profile-msg.error {
    color: #c0392b;
  }

  .btn-primary {
    width: 100%;
    background: var(--clr-primary);
    color: var(--clr-white);
    border-color: var(--clr-primary);
    border-radius: 12px;
    padding: 12px;
    font-size: 0.9rem;
    letter-spacing: 1px;
  }

  .profile-divider {
    height: 1px;
    background: var(--clr-border);
  }

  .btn-danger-outline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: transparent;
    border: solid 1.5px #e8b4b4;
    color: #c0392b;
    border-radius: 12px;
    padding: 11px;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: none;
    cursor: pointer;
    transition: var(--transition);
  }

  /* ── Dashboard ── */

  .dash-title {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--clr-text);
    opacity: 0.5;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .stat-cell {
    background: var(--clr-white2);
    border-radius: 14px;
    padding: 14px 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    text-align: center;
  }

  .stat-number {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--clr-text);
    line-height: 1;
    letter-spacing: -0.5px;
  }

  .stat-number.accent-green {
    color: var(--clr-primary);
  }

  .stat-number.accent-muted {
    color: var(--clr-text);
    opacity: 0.45;
  }

  .stat-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--clr-text);
    opacity: 0.45;
  }

  /* ── Top 3 ── */

  .top3-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .top3-empty {
    font-size: 0.85rem;
    color: var(--clr-text);
    opacity: 0.45;
    text-align: center;
    padding: 8px 0;
  }

  /* ── Hover ── */

  @media (hover: hover) {
    .back-link:hover {
      color: var(--clr-dark);
    }

    .btn-primary:hover {
      background: var(--clr-primary-dark);
      border-color: var(--clr-primary-dark);
    }

    .btn-danger-outline:hover {
      background: #fce8e8;
    }
  }

  @media (min-width: 768px) {
    .profile-page {
      max-width: 880px;
      padding: 32px 24px 80px;
      display: grid;
      grid-template-columns: 340px 1fr;
      grid-template-rows: auto 1fr;
      grid-template-areas:
        "back  back"
        "prof  dash";
      align-items: start;
      column-gap: 20px;
      row-gap: 20px;
    }

    .back-link   { grid-area: back; }
    .profile-card { grid-area: prof; }
    .dash-col    { grid-area: dash; }

    .profile-card,
    .dash-card {
      padding: 28px 24px;
    }

    .stat-cell {
      padding: 18px 8px;
    }

    .stat-number {
      font-size: 2rem;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";
  import { supabase } from "../lib/supabase.ts";
  import {
    clearCache,
    initCache,
    getRestaurants,
    getDishes,
    escapeHtml,
  } from "../lib/data.ts";

  const PROFILE_CACHE_KEY = "staurant_profile_v1";
  const DATA_CACHE_KEY = "staurant_cache_v4";

  // ─── Helpers de stats ───────────────────────────────────────────────────────

  interface RawRestaurant { id: string; status: string; name: string }
  interface RawDish { restaurantId: string; rating: number }

  function renderStats(
    restaurants: RawRestaurant[],
    dishes: RawDish[],
  ): void {
    const total = restaurants.length;
    const visited = restaurants.filter((r) => r.status === "visited").length;
    const pending = restaurants.filter((r) => r.status === "pending").length;
    const totalDishes = dishes.length;

    const avgAll =
      totalDishes > 0
        ? Math.round(
            (dishes.reduce((s, d) => s + d.rating, 0) / totalDishes) * 10,
          ) / 10
        : null;

    const ratedIds = new Set(dishes.map((d) => d.restaurantId));
    const rated = restaurants.filter((r) => ratedIds.has(r.id)).length;

    const set = (id: string, val: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    };
    set("sn-total", String(total));
    set("sn-visited", String(visited));
    set("sn-pending", String(pending));
    set("sn-dishes", String(totalDishes));
    set("sn-avg", avgAll !== null ? String(avgAll) : "—");
    set("sn-rated", String(rated));

    // Top 3
    const top3El = document.getElementById("top3-list");
    if (!top3El) return;

    const withAvg = restaurants
      .map((r) => {
        const rd = dishes.filter((d) => d.restaurantId === r.id);
        if (rd.length === 0) return null;
        const avg =
          Math.round(
            (rd.reduce((s, d) => s + d.rating, 0) / rd.length) * 10,
          ) / 10;
        return { name: r.name, avg };
      })
      .filter((x): x is { name: string; avg: number } => x !== null)
      .sort((a, b) => b.avg - a.avg)
      .slice(0, 3);

    if (withAvg.length === 0) {
      top3El.innerHTML =
        '<p class="top3-empty">Añade platos para ver tus favoritos</p>';
      return;
    }

    const medals = ["🥇", "🥈", "🥉"];
    top3El.innerHTML = withAvg
      .map((r, i) => {
        const badgeClass =
          r.avg >= 8 ? "badge-high" : r.avg >= 5 ? "badge-mid" : "badge-low";
        return `<div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(--clr-white2);border-radius:12px;">
          <span style="font-size:1.25rem;line-height:1;">${medals[i]}</span>
          <span style="flex:1;font-size:0.9rem;font-weight:600;color:var(--clr-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escapeHtml(r.name)}</span>
          <span class="${badgeClass}" style="font-size:0.82rem;font-weight:700;padding:3px 10px;border-radius:20px;flex-shrink:0;">${r.avg}</span>
        </div>`;
      })
      .join("");
  }

  // ─── PRE-RENDER en astro:after-swap ────────────────────────────────────────

  document.addEventListener("astro:after-swap", () => {
    const emailEl = document.getElementById("profile-email");
    if (!emailEl) return;
    try {
      const profileCached = JSON.parse(
        localStorage.getItem(PROFILE_CACHE_KEY) ?? "null",
      );
      if (profileCached) {
        emailEl.textContent = profileCached.email || "—";
        const nameInput = document.getElementById(
          "profile-name",
        ) as HTMLInputElement | null;
        const avatarEl = document.getElementById("profile-avatar");
        if (nameInput && profileCached.name) nameInput.value = profileCached.name;
        if (avatarEl && profileCached.name)
          avatarEl.textContent = profileCached.name.charAt(0).toUpperCase();
      }

      const dataCached = JSON.parse(
        localStorage.getItem(DATA_CACHE_KEY) ?? "null",
      );
      if (dataCached?.restaurants) {
        renderStats(dataCached.restaurants, dataCached.dishes ?? []);
      }
    } catch {
      /* ignore */
    }
  });

  // ─── Lógica principal ───────────────────────────────────────────────────────

  document.addEventListener("astro:page-load", async () => {
    const emailEl = document.getElementById("profile-email");
    if (!emailEl) return;

    const {
      data: { session },
    } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = "/login";
      return;
    }
    await initCache(session.user.id);

    // Back link contextual
    const fromTab =
      new URLSearchParams(window.location.search).get("from") ?? "visitados";
    const backLinkEl = document.querySelector(
      ".back-link",
    ) as HTMLAnchorElement;
    if (backLinkEl) backLinkEl.href = `/?tab=${fromTab}`;

    // Perfil
    const user = session.user;
    const nameInput = document.getElementById(
      "profile-name",
    ) as HTMLInputElement;
    const msgEl = document.getElementById("profile-msg")!;
    const avatarEl = document.getElementById("profile-avatar")!;

    emailEl.textContent = user.email ?? "";

    const { data: profile } = await supabase
      .from("profiles")
      .select("name")
      .eq("id", user.id)
      .single();

    if (profile?.name) {
      nameInput.value = profile.name;
      avatarEl.textContent = profile.name.charAt(0).toUpperCase();
    }

    localStorage.setItem(
      PROFILE_CACHE_KEY,
      JSON.stringify({ email: user.email ?? "", name: profile?.name ?? "" }),
    );

    // Stats desde el cache
    renderStats(getRestaurants(), getDishes());

    // Guardar nombre
    const form = document.getElementById("profile-form") as HTMLFormElement;
    form.onsubmit = async (e) => {
      e.preventDefault();
      msgEl.textContent = "";
      msgEl.classList.remove("error");

      const name = nameInput.value.trim();
      const btn = form.querySelector<HTMLButtonElement>(
        "button[type='submit']",
      )!;
      btn.disabled = true;
      btn.textContent = "Guardando...";

      const { error } = await supabase
        .from("profiles")
        .update({ name })
        .eq("id", user.id);

      if (error) {
        msgEl.textContent = "Error al guardar. Intenta de nuevo.";
        msgEl.classList.add("error");
      } else {
        msgEl.textContent = "¡Guardado correctamente!";
        if (name) {
          avatarEl.textContent = name.charAt(0).toUpperCase();
          localStorage.setItem(
            PROFILE_CACHE_KEY,
            JSON.stringify({ email: user.email ?? "", name }),
          );
        }
      }

      btn.disabled = false;
      btn.textContent = "Guardar cambios";
    };

    // Cerrar sesión
    const logoutBtn = document.getElementById("btn-logout")!;
    logoutBtn.onclick = async () => {
      clearCache();
      await supabase.auth.signOut();
      navigate("/login");
    };
  });
</script>
