---
interface Pill {
  field: string;
  label: string;
}

interface Props {
  pills: Pill[];
}

const { pills } = Astro.props;
---

<div class="sort-bar flex-row">
  <span class="sort-label">Ordenar</span>
  <div class="sort-pills flex-row">
    {
      pills.map((p) => (
        <button class="sort-pill" data-field={p.field}>
          <i class="bi bi-arrow-down-up" /> {p.label}
        </button>
      ))
    }
  </div>
</div>

<style>
  .sort-bar {
    justify-content: flex-start;
    gap: 8px;
    flex-wrap: wrap;
  }

  .sort-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--clr-text);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .sort-pills {
    justify-content: flex-start;
    gap: 6px;
    flex-wrap: wrap;
  }

  .sort-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 5px 12px;
    border-radius: 20px;
    border: solid 1.5px var(--clr-border);
    background: var(--clr-white);
    color: var(--clr-text);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: none;
    cursor: pointer;
    transition: var(--transition);
  }

  .sort-pill.active {
    background: var(--clr-primary);
    border-color: var(--clr-primary);
    color: var(--clr-white);
  }

  .sort-pill i {
    font-size: 0.65rem;
  }
</style>
