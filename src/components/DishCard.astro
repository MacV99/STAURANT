---
import type { Dish } from "../lib/data";
import RatingBadge from "./RatingBadge.astro";

interface Props {
  dish: Dish;
  typeName?: string | null;
}

const { dish: d, typeName } = Astro.props;
---

<article class="dish-card flex-row" data-id={d.id}>
  <RatingBadge score={d.rating} />
  <div class="dish-info">
    <h4>{d.name}</h4>
    {typeName && <span class="dish-type-tag">{typeName}</span>}
    {d.notes && <p class="dish-notes">{d.notes}</p>}
  </div>
  <div class="dish-actions flex-row">
    <div class="dish-menu">
      <button class="btn-menu boton2" data-id={d.id}>
        <i class="bi bi-three-dots-vertical"></i>
      </button>
      <div class="menu-popup">
        <button class="menu-item btn-edit-dish" data-id={d.id}>
          <i class="bi bi-pencil-fill"></i>
          <span>Editar</span>
        </button>
        <button class="menu-item btn-delete-dish" data-id={d.id}>
          <i class="bi bi-trash-fill"></i>
          <span>Eliminar</span>
        </button>
      </div>
    </div>
  </div>
</article>

<style>
  .dish-card {
    background: var(--clr-white);
    border: 1px solid var(--clr-border);
    border-radius: 14px;
    padding: 14px 16px;
    justify-content: space-between;
    gap: 12px;
    transition: var(--transition);
  }

  .dish-info {
    flex: 1;
    min-width: 0;
  }

  .dish-info h4 {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--clr-text);
  }

  .dish-type-tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.6px;
    text-indent: 0.6px;
    text-transform: uppercase;
    color: var(--clr-primary);
    background-color: var(--clr-white2);
    border-radius: 20px;
    padding: 2.5px 7px;
    margin-top: 2px;
  }

  .dish-info .dish-notes {
    font-size: 0.8rem;
    color: var(--clr-text);
    margin-top: 3px;
    line-height: 1.4;
    opacity: 0.75;
  }

  .dish-actions {
    gap: 6px;
    flex-shrink: 0;
  }
</style>
