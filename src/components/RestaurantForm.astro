---
import FormModal from "./FormModal.astro";
---

<FormModal id="restaurant-form" title="Nuevo restaurante" maxWidth="460px">
  <input type="hidden" id="rf-id" />
  <input type="hidden" id="rf-official-id" />

  <label for="rf-name">
    <span class="label-text flex-row">Nombre <span class="required">*</span></span>
    <div class="name-combobox" id="rf-name-combobox">
      <input
        type="text"
        id="rf-name"
        required
        autocomplete="off"
        spellcheck="false"
        placeholder="El Cielo, La Plaza..."
      />
      <div id="rf-name-dropdown" class="name-dropdown" hidden></div>
    </div>
  </label>

  <div class="city-field flex-column" id="rf-city-field">
    <span class="label-text flex-row">Ciudades <span class="optional">(opcional)</span></span>
    <div class="city-combobox" id="rf-city-combobox">
      <div class="city-input-wrap flex-row">
        <input
          type="text"
          id="rf-city"
          class="city-search-input"
          placeholder="Agrega una o varias ciudades..."
          autocomplete="off"
          spellcheck="false"
        />
        <span class="city-chevron" aria-hidden="true"><i class="bi bi-chevron-down"></i></span>
      </div>
      <div id="rf-city-dropdown" class="city-dropdown" hidden></div>
    </div>
    <div id="rf-city-chips" class="rf-city-chips flex-row" hidden></div>
  </div>

  <label for="rf-notes">
    <span class="label-text flex-row">Notas</span>
    <textarea
      id="rf-notes"
      rows="3"
      placeholder="Ambiente, ubicación, lo que quieras recordar..."
    ></textarea>
  </label>
</FormModal>

<style>
  /* ── Autocomplete oficial ─────────────────────────────────────────────── */

  .name-combobox {
    position: relative;
  }

  .name-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: var(--clr-white);
    border: 1.5px solid var(--clr-border);
    border-radius: var(--border-radius);
    z-index: 250;
    max-height: 260px;
    overflow-y: auto;
    overscroll-behavior: contain;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }

  /* ── Combobox de ciudad ───────────────────────────────────────────────── */

  .city-field {
    align-items: stretch;
    gap: 6px;
  }

  .city-combobox {
    position: relative;
  }

  .city-input-wrap {
    border: 1.5px solid var(--clr-border);
    border-radius: var(--border-radius);
    background: var(--clr-white);
    overflow: hidden;
    transition: border-color 0.12s ease;
  }

  .city-input-wrap:focus-within {
    border-color: var(--clr-border2);
  }

  .city-search-input {
    flex: 1;
    border: none !important;
    background: transparent !important;
    outline: none !important;
    box-shadow: none !important;
    padding: 10px 12px;
    font-size: 0.9rem;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--clr-text);
    min-width: 0;
  }

  .city-search-input::placeholder {
    text-transform: none;
    color: var(--clr-text);
    opacity: 0.5;
  }

  .city-chevron {
    padding: 0 10px 0 4px;
    color: var(--clr-text);
    opacity: 0.4;
    font-size: 0.75rem;
    flex-shrink: 0;
    pointer-events: none;
    transition: transform 0.15s ease;
  }

  .city-combobox.is-open .city-chevron {
    transform: rotate(180deg);
  }

  .city-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: var(--clr-white);
    border: 1.5px solid var(--clr-border);
    border-radius: var(--border-radius);
    z-index: 200;
    max-height: 220px;
    overflow-y: auto;
    overscroll-behavior: contain;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }

  /* ── Chips de ciudades agregadas ──────────────────────────────────────── */

  .rf-city-chips {
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    gap: 6px;
    margin-top: 4px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .rf-city-chips::-webkit-scrollbar {
    display: none;
  }

  .rf-city-chips[hidden] {
    display: none;
  }

  .rf-city-chips :global(.rf-city-pin) {
    color: var(--clr-primary);
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .rf-city-chips :global(.rf-city-chip) {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 4px 4px 4px 10px;
    border-radius: 50px;
    border: 1.5px solid var(--clr-border);
    background: var(--clr-white2);
    color: var(--clr-text);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .rf-city-chips :global(.rf-city-chip-x) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: var(--clr-text);
    opacity: 0.5;
    font-size: 0.58rem;
    cursor: pointer;
    flex-shrink: 0;
    transition: opacity 0.12s ease;
  }

  @media (hover: hover) {
    .rf-city-chips :global(.rf-city-chip-x:hover) {
      opacity: 1;
      color: var(--clr-danger);
    }
  }
</style>

<style is:global>
  /* Options son creadas via JS → necesitan scope global */

  #rf-name-dropdown .name-option {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 14px;
    cursor: pointer;
    border-bottom: 1px solid var(--clr-border);
    transition: background 0.1s ease;
  }

  #rf-name-dropdown .name-option:last-child {
    border-bottom: none;
  }

  @media (hover: hover) {
    #rf-name-dropdown .name-option:hover {
      background: var(--clr-white2);
    }
  }

  #rf-name-dropdown .name-option-title {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--clr-text);
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  #rf-name-dropdown .name-option-sub {
    font-size: 0.75rem;
    color: var(--clr-text);
    opacity: 0.6;
  }

  #rf-name-dropdown .name-option.is-loading,
  #rf-name-dropdown .name-option.is-empty {
    text-align: center;
    color: var(--clr-text);
    opacity: 0.55;
    font-size: 0.82rem;
    cursor: default;
    padding: 14px;
  }

  /* Opciones de ciudad creadas via JS → scope global */

  #rf-city-dropdown .city-option {
    padding: 11px 14px;
    font-size: 0.88rem;
    color: var(--clr-text);
    cursor: pointer;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    border-bottom: 1px solid var(--clr-border);
    transition: background 0.1s ease;
  }

  #rf-city-dropdown .city-option:last-child {
    border-bottom: none;
  }

  @media (hover: hover) {
    #rf-city-dropdown .city-option:hover {
      background: var(--clr-white2);
    }
  }

  #rf-city-dropdown .city-option.is-create {
    color: var(--clr-primary);
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    justify-content: flex-start;
    gap: 6px;
    border-top: 1px solid var(--clr-border);
  }

  #rf-city-dropdown .city-option.is-create i {
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  #rf-city-dropdown .city-option.is-create .create-name {
    font-weight: 700;
    text-transform: uppercase;
  }
</style>

<script>
  import type { Restaurant, OfficialRestaurant } from "../lib/data.ts";
  import {
    createRestaurant,
    updateRestaurant,
    getRestaurants,
    getCities,
    searchOfficialRestaurants,
    adoptOfficialRestaurant,
  } from "../lib/data.ts";
  import { emit, forceUppercase, createOverlay } from "../scripts/store.ts";
  import { navigate } from "astro:transitions/client";

  // Re-inicializar en cada navegación para que open/close siempre
  // operen sobre los elementos del DOM ACTUAL (no los del swap anterior).
  document.addEventListener("astro:page-load", () => {
    const overlayApi = createOverlay("restaurant-form-overlay", {
      onClose: () => hideDropdown(),
    });
    if (!overlayApi) return; // no está en esta página
    const { overlay, close } = overlayApi;

    const form       = document.getElementById("restaurant-form") as HTMLFormElement;
    const titleEl    = document.getElementById("restaurant-form-title")!;
    const idInput    = document.getElementById("rf-id") as HTMLInputElement;
    const officialIdInput = document.getElementById("rf-official-id") as HTMLInputElement;
    const nameInput  = document.getElementById("rf-name") as HTMLInputElement;
    const notesInput = document.getElementById("rf-notes") as HTMLTextAreaElement;
    const errorEl    = document.getElementById("restaurant-form-error")!;
    const closeBtn   = document.getElementById("restaurant-form-close")!;
    const cancelBtn  = document.getElementById("restaurant-form-cancel")!;
    const dropdownEl = document.getElementById("rf-name-dropdown") as HTMLElement;
    const submitBtn  = document.getElementById("restaurant-form-submit") as HTMLButtonElement;
    const cityCombobox = document.getElementById("rf-city-combobox") as HTMLElement;
    const cityInput  = document.getElementById("rf-city") as HTMLInputElement;
    const cityDropdown = document.getElementById("rf-city-dropdown") as HTMLElement;
    const cityChipsEl = document.getElementById("rf-city-chips") as HTMLElement;
    let selectedCities: string[] = [];

    function showDropdown(): void {
      dropdownEl.hidden = false;
    }
    function hideDropdown(): void {
      dropdownEl.hidden = true;
    }

    function renderResults(results: OfficialRestaurant[]): void {
      dropdownEl.innerHTML = "";
      if (results.length === 0) {
        hideDropdown();
        return;
      }
      results.forEach((o) => {
        const opt = document.createElement("div");
        opt.className = "name-option";
        const title = document.createElement("div");
        title.className = "name-option-title";
        title.innerHTML = `${o.name} <i class="bi bi-patch-check-fill verified-badge" title="Restaurante verificado"></i>`;
        opt.appendChild(title);
        if (o.city || o.address) {
          const sub = document.createElement("div");
          sub.className = "name-option-sub";
          sub.textContent = [o.city, o.address].filter(Boolean).join(" · ");
          opt.appendChild(sub);
        }
        // mousedown + preventDefault: evita blur del input antes del click
        opt.addEventListener("mousedown", (e) => e.preventDefault());
        opt.addEventListener("click", () => void adoptAndClose(o));
        dropdownEl.appendChild(opt);
      });
      showDropdown();
    }

    function renderLoading(): void {
      dropdownEl.innerHTML = "";
      const loading = document.createElement("div");
      loading.className = "name-option is-loading";
      loading.textContent = "Buscando...";
      dropdownEl.appendChild(loading);
      showDropdown();
    }

    async function adoptAndClose(o: OfficialRestaurant): Promise<void> {
      // Guarda la misma invariante de unicidad de nombre que el flujo manual.
      const duplicate = getRestaurants().find(
        (r) => r.name.trim().toLowerCase() === o.name.trim().toLowerCase(),
      );
      if (duplicate) {
        errorEl.textContent = `Ya tienes "${o.name}" en tu lista.`;
        hideDropdown();
        return;
      }
      // Bloquear UI mientras se clona la carta. NO cerrar el modal todavía:
      // si la adopción falla queremos seguir mostrando el error dentro del form.
      submitBtn.disabled = true;
      hideDropdown();
      errorEl.textContent = "";
      const created = await adoptOfficialRestaurant(o.id);
      submitBtn.disabled = false;
      if (created) {
        close();
        emit("restaurant:created", created);
        navigate(`/restaurante?id=${created.id}`);
      } else {
        errorEl.textContent = "No se pudo cargar el restaurante oficial. Intenta de nuevo.";
      }
    }

    let searchToken = 0;
    let searchTimer: number | undefined;
    function scheduleSearch(query: string): void {
      if (searchTimer) clearTimeout(searchTimer);
      const q = query.trim();
      if (q.length < 2) { hideDropdown(); return; }
      searchTimer = window.setTimeout(async () => {
        const token = ++searchToken;
        renderLoading();
        const results = await searchOfficialRestaurants(q);
        if (token !== searchToken) return; // respuesta obsoleta
        renderResults(results);
      }, 220);
    }

    // ─── Combobox de ciudades (multi: se van agregando como chips) ────────────

    function renderCityChips(): void {
      cityChipsEl.innerHTML = "";
      cityChipsEl.hidden = selectedCities.length === 0;
      if (selectedCities.length === 0) return;

      // Un solo pin al inicio, y luego todas las ciudades.
      const pin = document.createElement("i");
      pin.className = "bi bi-geo-alt-fill rf-city-pin";
      cityChipsEl.appendChild(pin);

      selectedCities.forEach((c) => {
        const chip = document.createElement("span");
        chip.className = "rf-city-chip";
        const label = document.createElement("span");
        label.className = "rf-city-chip-label";
        label.textContent = c;
        chip.appendChild(label);
        const x = document.createElement("button");
        x.type = "button";
        x.className = "rf-city-chip-x";
        x.setAttribute("aria-label", `Quitar ${c}`);
        x.innerHTML = `<i class="bi bi-x-lg"></i>`;
        x.addEventListener("mousedown", (e) => e.preventDefault());
        x.onclick = () => removeCity(c);
        chip.appendChild(x);
        cityChipsEl.appendChild(chip);
      });
    }

    function addCity(value: string): void {
      const v = value.trim().toUpperCase();
      if (!v) return;
      if (!selectedCities.includes(v)) selectedCities.push(v);
      renderCityChips();
      cityInput.value = "";
      renderCityDropdown(""); // refresca sugerencias (ya sin la recién agregada)
      cityInput.focus();
    }

    function removeCity(value: string): void {
      selectedCities = selectedCities.filter((c) => c !== value);
      renderCityChips();
    }

    function renderCityDropdown(query: string): void {
      const q = query.trim().toUpperCase();
      // Sugerencias = ciudades ya usadas por el usuario, menos las ya agregadas aquí.
      const all = getCities().filter((c) => !selectedCities.includes(c));
      const filtered = q ? all.filter((c) => c.includes(q)) : all;
      const exactMatch = all.includes(q);
      cityDropdown.innerHTML = "";

      filtered.forEach((c) => {
        const opt = document.createElement("div");
        opt.className = "city-option";
        opt.textContent = c;
        opt.addEventListener("mousedown", (e) => e.preventDefault());
        opt.addEventListener("click", () => addCity(c));
        cityDropdown.appendChild(opt);
      });

      // Opción para agregar una nueva (texto que no coincide con una existente
      // ni con una ya agregada)
      if (q && !exactMatch && !selectedCities.includes(q)) {
        const createOpt = document.createElement("div");
        createOpt.className = "city-option is-create flex-row";
        createOpt.innerHTML = `<i class="bi bi-plus-lg"></i> Agregar "<span class="create-name"></span>"`;
        createOpt.querySelector(".create-name")!.textContent = q;
        createOpt.addEventListener("mousedown", (e) => e.preventDefault());
        createOpt.addEventListener("click", () => addCity(q));
        cityDropdown.appendChild(createOpt);
      }

      if (cityDropdown.childElementCount === 0) {
        closeCityDropdown();
        return;
      }
      cityDropdown.hidden = false;
      cityCombobox.classList.add("is-open");
    }

    function openCityDropdown(): void {
      renderCityDropdown(cityInput.value);
    }
    function closeCityDropdown(): void {
      cityDropdown.hidden = true;
      cityCombobox.classList.remove("is-open");
    }

    cityInput.oninput = () => {
      forceUppercase(cityInput);
      openCityDropdown();
    };
    cityInput.onfocus = () => openCityDropdown();
    cityInput.onblur = () => {
      setTimeout(() => {
        if (!cityCombobox.contains(document.activeElement)) closeCityDropdown();
      }, 150);
    };
    // Enter agrega la ciudad escrita en vez de enviar el formulario.
    cityInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        addCity(cityInput.value);
      }
    });

    function open(mode: "create" | "edit", data?: Restaurant) {
      errorEl.textContent = "";
      form.reset();
      officialIdInput.value = "";
      hideDropdown();
      closeCityDropdown();
      selectedCities = mode === "edit" && data ? [...data.cities] : [];
      renderCityChips();
      if (mode === "edit" && data) {
        titleEl.textContent = "Editar restaurante";
        idInput.value   = data.id;
        nameInput.value = data.name;
        notesInput.value = data.notes;
      } else {
        titleEl.textContent = "Nuevo restaurante";
        idInput.value = "";
      }
      overlay.classList.add("is-open");
    }

    // .onclick evita acumulación de listeners si el módulo re-ejecuta
    closeBtn.onclick  = close;
    cancelBtn.onclick = close;

    nameInput.oninput = () => {
      forceUppercase(nameInput);
      // Solo buscar oficiales en modo creación (no edición)
      if (idInput.value) return;
      scheduleSearch(nameInput.value);
    };

    nameInput.onblur = () => {
      // delay para permitir click en opciones (mousedown ya previene blur,
      // pero por seguridad cerramos al perder foco fuera del combobox)
      setTimeout(() => {
        const combobox = document.getElementById("rf-name-combobox");
        if (!combobox?.contains(document.activeElement)) hideDropdown();
      }, 150);
    };

    nameInput.onfocus = () => {
      if (idInput.value) return;
      if (nameInput.value.trim().length >= 2) scheduleSearch(nameInput.value);
    };

    form.onsubmit = (e) => {
      e.preventDefault();
      errorEl.textContent = "";
      const name = nameInput.value.trim();
      if (!name) { errorEl.textContent = "El nombre es obligatorio."; nameInput.focus(); return; }

      const id = idInput.value;
      const duplicate = getRestaurants().find(
        r => r.name.trim().toLowerCase() === name.toLowerCase() && r.id !== id
      );
      if (duplicate) { errorEl.textContent = "Ya existe un restaurante con ese nombre."; nameInput.focus(); return; }

      const notes = notesInput.value.trim();
      // Incluye lo que quedó escrito en el input sin confirmar como un chip.
      addCity(cityInput.value);
      const cities = [...selectedCities];

      // Cerrar ANTES de emitir: garantiza que el modal cierra aunque
      // el listener del evento lance una excepción.
      close();

      if (id) {
        const updated = updateRestaurant(id, { name, notes, cities });
        if (updated) emit("restaurant:updated", updated);
      } else {
        emit("restaurant:created", createRestaurant({ name, notes, cities }));
      }
    };

    // Actualizar API global con referencias frescas al DOM actual
    (window as any).restaurantForm = { open, close };
  });
</script>
