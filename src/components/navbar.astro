---
const pathname = Astro.url.pathname;
const isHome = pathname === "/" || pathname.endsWith("/index");
const isPerfil = pathname.includes("/perfil");
const fabIcon = pathname.includes("/restaurante")
  ? "bi bi-fork-knife"
  : "bi bi-shop-window";
---

<!-- ── Mobile header ───────────────────────────────────────────── -->
<header class="mobile-header">
  <a href="/" class="brand-link" aria-label="Inicio">
    <img src="/img/logo2.png" alt="STAURANT" class="brand-logo" />
  </a>
</header>

<!-- ── Desktop sidebar ─────────────────────────────────────────── -->
<aside class="desktop-sidebar">
  <a href="/" class="brand-link" aria-label="Inicio">
    <img src="/img/logo2.png" alt="STAURANT" class="brand-logo" />
  </a>

  <nav class="sidebar-nav" aria-label="Navegación">
    <a
      href="/"
      class:list={["sidebar-item", { active: isHome }]}
      aria-current={isHome ? "page" : undefined}
    >
      <i class={isHome ? "bi bi-house-door-fill" : "bi bi-house-door"}></i>
      <span>Inicio</span>
    </a>

    <a
      href="/perfil"
      class:list={["sidebar-item", { active: isPerfil }]}
      aria-current={isPerfil ? "page" : undefined}
    >
      <i class={isPerfil ? "bi bi-person-fill" : "bi bi-person"}></i>
      <span>Perfil</span>
    </a>
  </nav>

  <button
    type="button"
    class="sidebar-item sidebar-create"
    data-action="create"
    aria-label="Crear restaurante o plato"
  >
    <span class="fab-inner sidebar-create-icon">
      <i class={fabIcon}></i>
      <span class="fab-badge">+</span>
    </span>
    <span>Crear</span>
  </button>
</aside>

<!-- ── Mobile bottom nav ───────────────────────────────────────── -->
<nav class="mobile-bottom-nav" aria-label="Navegación móvil">
  <a
    href="/"
    class:list={["nav-item", { active: isHome }]}
    aria-current={isHome ? "page" : undefined}
  >
    <i class={isHome ? "bi bi-house-door-fill" : "bi bi-house-door"}></i>
    <span>Inicio</span>
  </a>

  <button
    type="button"
    class="nav-item nav-fab"
    data-action="create"
    aria-label="Crear restaurante o plato"
  >
    <span class="fab-inner">
      <i class={fabIcon}></i>
      <span class="fab-badge">+</span>
    </span>
  </button>

  <a
    href="/perfil"
    class:list={["nav-item", { active: isPerfil }]}
    aria-current={isPerfil ? "page" : undefined}
  >
    <i class={isPerfil ? "bi bi-person-fill" : "bi bi-person"}></i>
    <span>Perfil</span>
  </a>
</nav>

<script>
  function updateActiveState(): void {
    const { pathname } = window.location;
    const isHome = pathname === "/" || pathname.endsWith("/index");
    const isPerfil = pathname.includes("/perfil");

    const sets = [
      {
        root: ".mobile-bottom-nav",
        homeClass: "nav-item",
        perfilClass: "nav-item",
      },
      {
        root: ".desktop-sidebar",
        homeClass: "sidebar-item",
        perfilClass: "sidebar-item",
      },
    ] as const;

    for (const { root } of sets) {
      const homeEl = document.querySelector(
        `${root} a[href="/"]`,
      ) as HTMLElement | null;
      const perfilEl = document.querySelector(
        `${root} a[href="/perfil"]`,
      ) as HTMLElement | null;

      homeEl?.classList.toggle("active", isHome);
      perfilEl?.classList.toggle("active", isPerfil);

      const homeIcon = homeEl?.querySelector("i") as HTMLElement | null;
      const perfilIcon = perfilEl?.querySelector("i") as HTMLElement | null;
      if (homeIcon)
        homeIcon.className = isHome
          ? "bi bi-house-door-fill"
          : "bi bi-house-door";
      if (perfilIcon)
        perfilIcon.className = isPerfil ? "bi bi-person-fill" : "bi bi-person";
    }
  }

  function updateFabIcon(): void {
    const cls = window.location.pathname.includes("/restaurante")
      ? "bi bi-fork-knife"
      : "bi bi-shop-window";
    document
      .querySelectorAll("[data-action='create'] .fab-inner > i")
      .forEach((el) => {
        (el as HTMLElement).className = cls;
      });
  }

  function initFab(): void {
    document.querySelectorAll("[data-action='create']").forEach((btn) => {
      (btn as HTMLElement).onclick = (e) => {
        e.preventDefault();
        const { pathname } = window.location;
        if (pathname === "/" || pathname.endsWith("/index")) {
          (window as any).restaurantForm?.open("create");
          return;
        }
        if (pathname.includes("/restaurante")) {
          const id = new URLSearchParams(window.location.search).get("id");
          if (id) {
            (window as any).dishForm?.open("create", id);
            return;
          }
        }
        window.location.href = "/";
      };
    });
  }

  document.addEventListener("astro:page-load", () => {
    updateActiveState();
    updateFabIcon();
    initFab();
  });
</script>

<style>
  /* ── Animación FAB (keyframes globales por spec CSS) ──────────── */
  @keyframes fab-icon-cycle {
    0%,
    75% {
      opacity: 1;
      transform: scale(1);
    }
    85%,
    92% {
      opacity: 0;
      transform: scale(0.3);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes fab-badge-cycle {
    0%,
    75% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.3);
    }
    85%,
    92% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.3);
    }
  }

  .fab-inner {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .fab-inner > i {
    animation: fab-icon-cycle 8s ease-in-out infinite;
  }

  .fab-badge {
    position: absolute;
    top: 50%;
    left: 50%;
    color: white;
    font-weight: 450;
    line-height: 1;
    pointer-events: none;
    animation: fab-badge-cycle 8s ease-in-out infinite;
  }

  /* ── Brand ─────────────────────────────────────────────────────── */
  .brand-link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .mobile-header .brand-link {
    height: 100%;
  }

  .mobile-header .brand-logo {
    height: 100%;
    width: auto;
    object-fit: contain;
    transform: translateY(9px);
  }

  .desktop-sidebar .brand-logo {
    height: 54px;
    width: auto;
    max-width: 210px;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* ── Mobile header ──────────────────────────────────────────────── */
  .mobile-header {
    display: none;
    position: sticky;
    top: 0;
    align-items: center;
    justify-content: center;
    height: 60px;
    width: 100%;
    background-color: var(--clr-white2);
    background-image: radial-gradient(circle, #c8c8c8 1px, transparent 1px);
    background-size: 20px 20px;
    z-index: 100;
  }

  /* ── Desktop sidebar ────────────────────────────────────────────── */
  .desktop-sidebar {
    display: none;
    flex-direction: column;
    width: 240px;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    height: 100dvh;
    padding: 24px 14px;
    gap: 6px;
    background: var(--clr-white);
    border-right: solid 1px var(--clr-border);
    overflow-y: auto;
    z-index: 100;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 16px;
    width: 100%;
    flex: 1;
  }

  .sidebar-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 50px;
    color: var(--clr-text);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    background: transparent;
    border: none;
    width: 100%;
    text-align: left;
    transition: var(--transition);
  }

  .sidebar-item i {
    font-size: 1.25rem;
    color: var(--clr-primary);
    flex-shrink: 0;
  }

  .sidebar-item.active {
    font-weight: 700;
  }

  .sidebar-item.active i {
    color: var(--clr-text);
  }

  .sidebar-create {
    margin-top: auto;
    background: var(--clr-primary);
    color: var(--clr-white);
  }

  .sidebar-create-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    overflow: hidden;
  }

  .sidebar-create-icon > i {
    font-size: 1.25rem;
    color: var(--clr-white);
  }

  .sidebar-create .fab-badge {
    font-size: 1.9rem;
    color: var(--clr-white);
  }

  /* ── Mobile bottom nav ──────────────────────────────────────────── */
  .mobile-bottom-nav {
    display: none;
    position: fixed;
    left: 0;
    bottom: 0;
    width: 100%;
    padding: 10px 14px calc(10px + env(safe-area-inset-bottom));
    gap: 10px;
    justify-content: space-between;
    align-items: center;
    background: #fff;
    box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.08);
    border-radius: 18px 18px 0 0;
    z-index: 125;
  }

  .nav-item {
    display: flex;
    flex: 1 1 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    min-height: 62px;
    padding: 10px 4px;
    color: var(--clr-primary);
    font-size: 0.75rem;
    text-decoration: none;
    border-radius: 16px;
    cursor: pointer;
    background: transparent;
    border: none;
    transition: var(--transition);
  }

  .nav-item i {
    font-size: 1.2rem;
    line-height: 1;
  }

  .nav-item.active {
    color: var(--clr-text);
  }

  .nav-item.active span {
    font-weight: 700;
  }

  .nav-fab {
    flex: 0 0 62px;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    border: none;
    background: var(--clr-primary);
    color: var(--clr-white);
    box-shadow:
      0 4px 16px rgba(84, 107, 65, 0.45),
      0 2px 6px rgba(0, 0, 0, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateY(-18px);
    padding: 0;
    z-index: 130;
    transition: var(--transition);
  }

  .nav-fab .fab-inner {
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
  }

  .nav-fab .fab-inner > i {
    font-size: 1.5rem;
  }

  .nav-fab .fab-badge {
    font-size: 2.5rem;
  }

  /* ── Hover (pointer devices only) ──────────────────────────────── */
  @media (hover: hover) {
    .sidebar-item:hover {
      background: var(--clr-white2);
    }

    .nav-item:not(.nav-fab):hover {
      background: var(--clr-white2);
    }

    .nav-fab:hover {
      filter: brightness(1.08);
    }
  }

  /* ── Responsive: mobile ─────────────────────────────────────────── */
  @media (max-width: 767px) {
    .mobile-header {
      display: flex;
    }
    .mobile-bottom-nav {
      display: flex;
    }
  }

  /* ── Responsive: desktop ────────────────────────────────────────── */
  @media (min-width: 768px) {
    .desktop-sidebar {
      display: flex;
    }
  }
</style>
