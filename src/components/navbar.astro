---
const pathname = Astro.url.pathname;
const isHome = pathname === "/" || pathname.endsWith("/index");
const isPerfil = pathname.includes("/perfil");
const fabIcon = pathname.includes("/restaurante") ? "bi bi-fork-knife" : "bi bi-shop-window";
---

<nav class="mobile-bottom-nav" aria-label="Navegación móvil">
  <a
    href="/"
    class:list={["nav-item", "flex-column", { active: isHome }]}
    aria-label="Inicio"
    aria-current={isHome ? "page" : undefined}
  >
    <i class={isHome ? "bi bi-house-door-fill" : "bi bi-house-door"}></i>
    <span>Inicio</span>
  </a>

  <button
    type="button"
    class="nav-item nav-fab"
    data-action="create"
    aria-label="Crear restaurante o plato"
  >
    <span class="fab-inner">
      <i class={fabIcon}></i>
      <span class="fab-badge">+</span>
    </span>
  </button>

  <a
    href="/perfil"
    class:list={["nav-item", "flex-column", { active: isPerfil }]}
    aria-label="Perfil"
    aria-current={isPerfil ? "page" : undefined}
  >
    <i class={isPerfil ? "bi bi-person-fill" : "bi bi-person"}></i>
    <span>Perfil</span>
  </a>
</nav>

<script>
  function updateActiveState(): void {
    const pathname = window.location.pathname;
    const isHome = pathname === "/" || pathname.endsWith("/index");
    const isPerfil = pathname.includes("/perfil");

    const homeLink = document.querySelector(
      '.mobile-bottom-nav a[href="/"]',
    ) as HTMLAnchorElement | null;
    const perfilLink = document.querySelector(
      '.mobile-bottom-nav a[href="/perfil"]',
    ) as HTMLAnchorElement | null;

    homeLink?.classList.toggle("active", isHome);
    perfilLink?.classList.toggle("active", isPerfil);

    const homeIcon = homeLink?.querySelector("i");
    const perfilIcon = perfilLink?.querySelector("i");

    if (homeIcon) homeIcon.className = isHome ? "bi bi-house-door-fill" : "bi bi-house-door";
    if (perfilIcon) perfilIcon.className = isPerfil ? "bi bi-person-fill" : "bi bi-person";
  }

  function updateFabIcon(): void {
    const fabIcon = document.querySelector(".nav-fab .fab-inner > i") as HTMLElement | null;
    if (!fabIcon) return;
    fabIcon.className = window.location.pathname.includes("/restaurante")
      ? "bi bi-fork-knife"
      : "bi bi-shop-window";
  }

  document.addEventListener("astro:page-load", () => {
    updateActiveState();
    updateFabIcon();

    const fabBtn = document.querySelector(".nav-fab") as HTMLButtonElement | null;
    if (!fabBtn) return;

    fabBtn.onclick = (event) => {
      event.preventDefault();
      const pathname = window.location.pathname;

      if (pathname === "/" || pathname.endsWith("/index")) {
        (window as any).restaurantForm?.open("create");
        return;
      }

      if (pathname.includes("/restaurante")) {
        const restaurantId = new URLSearchParams(window.location.search).get("id");
        if (restaurantId) {
          (window as any).dishForm?.open("create", restaurantId);
          return;
        }
      }

      window.location.href = "/";
    };
  });
</script>
