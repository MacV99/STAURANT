<script>
  import type { Dish } from "../lib/data.ts";
  import {
    createDish,
    updateDish,
    getDishesByRestaurant,
    getDishTypes,
    createDishType,
  } from "../lib/data.ts";
  import { emit } from "../scripts/store.ts";

  // Re-inicializar en cada navegación para que open/close siempre
  // operen sobre los elementos del DOM ACTUAL (no los del swap anterior).
  document.addEventListener("astro:page-load", () => {
    const overlayEl = document.getElementById("dish-form-overlay");
    if (!overlayEl) return; // no está en esta página
    const overlay: HTMLElement = overlayEl;

    const form = document.getElementById("dish-form") as HTMLFormElement;
    const titleEl = document.getElementById("dish-form-title")!;
    const idInput = document.getElementById("df-id") as HTMLInputElement;
    const restaurantIdInput = document.getElementById(
      "df-restaurant-id",
    ) as HTMLInputElement;
    const typeIdInput = document.getElementById(
      "df-type-id",
    ) as HTMLInputElement;
    const nameInput = document.getElementById("df-name") as HTMLInputElement;
    const ratingInput = document.getElementById(
      "df-rating",
    ) as HTMLInputElement;
    const notesInput = document.getElementById(
      "df-notes",
    ) as HTMLTextAreaElement;
    const errorEl = document.getElementById("df-error")!;
    const closeBtn = document.getElementById("dish-form-close")!;
    const cancelBtn = document.getElementById("dish-form-cancel")!;
    const ratingClearBtn = document.getElementById(
      "df-rating-clear",
    ) as HTMLButtonElement;
    const drumOuterEl = document.getElementById("df-drum-outer") as HTMLElement;
    const drumEl = document.getElementById("df-rating-drum") as HTMLElement;
    const drumTrackEl = document.getElementById("df-drum-track") as HTMLElement;

    let isRated = false;

    function setRated(rated: boolean, value?: number) {
      isRated = rated;
      ratingClearBtn.hidden = !rated;
      drumOuterEl.classList.toggle("is-unrated", !rated);
      if (rated) {
        const v = value ?? parseFloat(ratingInput.value);
        ratingInput.value = String(v);
      }
    }

    ratingClearBtn.onclick = (e) => {
      e.stopPropagation();
      setRated(false);
    };
    drumOuterEl.onclick = () => {
      if (!isRated) setRated(true);
    };

    // ─── Combobox de tipo ──────────────────────────────────────────────────────

    const comboboxEl = document.getElementById("df-type-combobox")!;
    const searchInput = document.getElementById(
      "df-type-search",
    ) as HTMLInputElement;
    const clearBtn = document.getElementById(
      "df-type-clear",
    ) as HTMLButtonElement;
    const dropdownEl = document.getElementById(
      "df-type-dropdown",
    ) as HTMLElement;

    let selectedTypeId: string | null = null;

    function openDropdown() {
      renderDropdown(searchInput.value);
      dropdownEl.hidden = false;
      comboboxEl.classList.add("is-open");
    }

    function closeDropdown() {
      dropdownEl.hidden = true;
      comboboxEl.classList.remove("is-open");
      // Restaurar el nombre del tipo seleccionado si el input quedó con texto parcial
      if (selectedTypeId) {
        const t = getDishTypes().find((t) => t.id === selectedTypeId);
        searchInput.value = t?.name ?? "";
      } else {
        searchInput.value = "";
      }
    }

    function selectType(id: string | null, name: string | null) {
      selectedTypeId = id;
      typeIdInput.value = id ?? "";
      searchInput.value = name ?? "";
      clearBtn.hidden = !id;
      closeDropdown();
    }

    function renderDropdown(query: string) {
      const types = getDishTypes();
      const q = query.trim().toUpperCase();
      const filtered = q ? types.filter((t) => t.name.includes(q)) : types;
      const exactMatch = types.some((t) => t.name === q);

      dropdownEl.innerHTML = "";

      // Opción "ninguno" para deseleccionar (solo cuando hay algo seleccionado)
      if (selectedTypeId) {
        const noneOpt = document.createElement("div");
        noneOpt.className = "type-option is-none";
        noneOpt.textContent = "— Sin tipo";
        noneOpt.addEventListener("mousedown", (e) => e.preventDefault());
        noneOpt.addEventListener("click", () => selectType(null, null));
        dropdownEl.appendChild(noneOpt);
      }

      // Opciones existentes
      filtered.forEach((t) => {
        const opt = document.createElement("div");
        opt.className =
          "type-option" + (t.id === selectedTypeId ? " is-selected" : "");
        opt.textContent = t.name;
        opt.addEventListener("mousedown", (e) => e.preventDefault());
        opt.addEventListener("click", () => selectType(t.id, t.name));
        dropdownEl.appendChild(opt);
      });

      // Opción para crear (solo si el texto no coincide exactamente)
      if (q && !exactMatch) {
        const createOpt = document.createElement("div");
        createOpt.className = "type-option is-create flex-row";
        createOpt.innerHTML = `<i class="bi bi-plus-lg"></i> Crear "<span class="create-name">${q}</span>"`;
        createOpt.addEventListener("mousedown", (e) => e.preventDefault());
        createOpt.addEventListener("click", () => {
          // Verificar que no exista ya (race condition)
          const existing = getDishTypes().find((t) => t.name === q);
          if (existing) {
            selectType(existing.id, existing.name);
          } else {
            const newType = createDishType(q);
            selectType(newType.id, newType.name);
          }
        });
        dropdownEl.appendChild(createOpt);
      }

      // Estado vacío
      if (dropdownEl.childElementCount === 0) {
        const emptyOpt = document.createElement("div");
        emptyOpt.className = "type-option is-empty";
        emptyOpt.textContent = "Escribe para crear tu primera etiqueta";
        dropdownEl.appendChild(emptyOpt);
      }
    }

    // Input: filtra mientras escribe
    searchInput.addEventListener("input", () => {
      // Forzar UPPERCASE
      const pos = searchInput.selectionStart;
      searchInput.value = searchInput.value.toUpperCase();
      searchInput.setSelectionRange(pos, pos);
      // Limpiar selección actual si el usuario está escribiendo algo nuevo
      selectedTypeId = null;
      typeIdInput.value = "";
      clearBtn.hidden = true;
      if (dropdownEl.hidden) openDropdown();
      else renderDropdown(searchInput.value);
    });

    // Abrir al hacer focus / click
    searchInput.addEventListener("focus", () => {
      if (dropdownEl.hidden) openDropdown();
    });
    searchInput.addEventListener("click", () => {
      if (dropdownEl.hidden) openDropdown();
    });

    // Cerrar al perder foco (con delay para permitir el click en opciones)
    searchInput.addEventListener("blur", () => {
      setTimeout(() => {
        if (!comboboxEl.contains(document.activeElement)) {
          closeDropdown();
        }
      }, 150);
    });

    // Botón X para limpiar la selección (mousedown evita blur del input)
    clearBtn.addEventListener("mousedown", (e) => e.preventDefault());
    clearBtn.addEventListener("click", () => {
      selectType(null, null);
      searchInput.focus();
    });

    // Inicializa el combobox con un tipo pre-seleccionado (o sin selección)
    function initTypeCombobox(selectedId: string | null) {
      selectedTypeId = selectedId;
      typeIdInput.value = selectedId ?? "";
      dropdownEl.hidden = true;
      comboboxEl.classList.remove("is-open");
      if (selectedId) {
        const t = getDishTypes().find((t) => t.id === selectedId);
        searchInput.value = t?.name ?? "";
        clearBtn.hidden = false;
      } else {
        searchInput.value = "";
        clearBtn.hidden = true;
      }
    }

    // ─── Apertura / cierre del modal ──────────────────────────────────────────

    function open(mode: "create" | "edit", restaurantId: string, data?: Dish) {
      errorEl.textContent = "";
      form.reset();
      restaurantIdInput.value = restaurantId;

      if (mode === "edit" && data) {
        titleEl.textContent = "Editar plato";
        idInput.value = data.id;
        nameInput.value = data.name;
        notesInput.value = data.notes;
        if (data.rating !== null) {
          setRated(true, data.rating);
        } else {
          ratingInput.value = "5";
          setRated(false);
        }
        initTypeCombobox(data.typeId ?? null);
      } else {
        titleEl.textContent = "Nuevo plato";
        idInput.value = "";
        ratingInput.value = "5";
        setRated(false);
        initTypeCombobox(null);
      }

      overlay.classList.add("is-open");
      requestAnimationFrame(() =>
        initDrumForValue(parseFloat(ratingInput.value)),
      );
    }

    function close() {
      closeDropdown();
      overlay.classList.remove("is-open");
    }

    // .onclick evita acumulación de listeners si el módulo re-ejecuta
    closeBtn.onclick = close;
    cancelBtn.onclick = close;
    overlay.onclick = (e) => {
      if (e.target === overlay) close();
    };

    // ─── Drum picker ──────────────────────────────────────────────────────────

    const ITEM_W = 52;
    const MIN_V = 1.0;
    const NUM_ITEMS = 91; // 1.0 → 10.0 at 0.1 steps
    // Espacio extra simétrico a cada lado para permitir rebote/overscroll
    // pasando el 1 (izq) y el 10 (der). El snap JS regresa al item.
    const OVERSCROLL = Math.round(ITEM_W * 0.55);

    const drumItems: HTMLElement[] = [];
    let prevDrumV = -1;
    let prevCenter = -1;
    let drumBuilt = false;
    let startSpacer: HTMLElement | null = null;
    let endSpacer: HTMLElement | null = null;

    // scrollLeft que centra el item idx (las dos spacers añaden OVERSCROLL al origen).
    const scrollLeftFor = (idx: number) => idx * ITEM_W + OVERSCROLL;
    const idxFromScrollLeft = () =>
      Math.max(
        0,
        Math.min(
          NUM_ITEMS - 1,
          Math.round((drumEl.scrollLeft - OVERSCROLL) / ITEM_W),
        ),
      );

    function syncDrumPadding() {
      const w = drumEl.getBoundingClientRect().width;
      if (w === 0) return; // not laid out yet — wait for ResizeObserver
      const pad = Math.max(0, w / 2 - ITEM_W / 2);
      // Spacers simétricos + OVERSCROLL: item 1 e item 10 centran igual,
      // y queda un poco de cuerda para rebotar a cada lado.
      const spacer = pad + OVERSCROLL;
      if (startSpacer) startSpacer.style.flex = `0 0 ${spacer}px`;
      if (endSpacer) endSpacer.style.flex = `0 0 ${spacer}px`;
    }

    // Drum-picker width may be 0 at first measurement (modal mid-open, dvh shift,
    // rotation). Re-sync spacers whenever it resizes and re-anchor the current
    // value so item 10 stays reachable.
    const drumResizeObserver = new ResizeObserver(() => {
      if (!drumBuilt) return;
      const prevIdx = idxFromScrollLeft();
      syncDrumPadding();
      drumEl.scrollLeft = scrollLeftFor(prevIdx);
    });
    drumResizeObserver.observe(drumEl);

    function buildDrum() {
      if (drumBuilt) return;
      drumBuilt = true;
      drumTrackEl.innerHTML = "";
      drumItems.length = 0;

      startSpacer = document.createElement("div");
      startSpacer.style.flexShrink = "0";
      startSpacer.setAttribute("aria-hidden", "true");
      drumTrackEl.appendChild(startSpacer);

      for (let i = 0; i < NUM_ITEMS; i++) {
        const v = parseFloat((MIN_V + i * 0.1).toFixed(1));
        const tenths = Math.round(v * 10) % 10;
        const item = document.createElement("div");
        item.className = "drum-item";
        item.textContent = tenths === 0 ? String(Math.round(v)) : String(v);
        item.style.opacity = "0.04";
        item.style.transform = "scale(0.25)";
        drumTrackEl.appendChild(item);
        drumItems.push(item);
      }

      endSpacer = document.createElement("div");
      endSpacer.style.flexShrink = "0";
      endSpacer.setAttribute("aria-hidden", "true");
      drumTrackEl.appendChild(endSpacer);
    }

    function updateDrumVisuals(centerIdx: number) {
      if (centerIdx === prevCenter) return;
      const RADIUS = 4;
      const opacities = [1, 0.55, 0.28, 0.14, 0.07];
      const scales = [1, 0.72, 0.52, 0.38, 0.28];
      const lo = Math.max(0, centerIdx - RADIUS);
      const hi = Math.min(NUM_ITEMS - 1, centerIdx + RADIUS);
      const CENTER_GAP = 8; // px extra separation around the center
      if (prevCenter >= 0) {
        const prevLo = Math.max(0, prevCenter - RADIUS);
        const prevHi = Math.min(NUM_ITEMS - 1, prevCenter + RADIUS);
        for (let i = prevLo; i <= prevHi; i++) {
          if (i < lo || i > hi) {
            const shift = Math.sign(i - centerIdx) * CENTER_GAP;
            drumItems[i].style.opacity = "0.04";
            drumItems[i].style.transform = `translateX(${shift}px) scale(0.25)`;
            drumItems[i].classList.remove("is-center");
          }
        }
      }
      for (let i = lo; i <= hi; i++) {
        const dist = Math.abs(i - centerIdx);
        const shift = Math.sign(i - centerIdx) * CENTER_GAP;
        drumItems[i].style.opacity = String(opacities[dist] ?? 0.04);
        drumItems[i].style.transform = `translateX(${shift}px) scale(${scales[dist] ?? 0.25})`;
        drumItems[i].classList.toggle("is-center", dist === 0);
      }
      prevCenter = centerIdx;
    }

    let scrollSnapTimer: number | undefined;
    let isTouching = false;

    function snapToNearest() {
      const target = scrollLeftFor(idxFromScrollLeft());
      if (Math.abs(drumEl.scrollLeft - target) > 0.5) {
        drumEl.scrollTo({ left: target, behavior: "smooth" });
      }
    }

    drumEl.addEventListener(
      "scroll",
      () => {
        const idx = idxFromScrollLeft();
        const v = parseFloat((MIN_V + idx * 0.1).toFixed(1));
        updateDrumVisuals(idx);
        if (v !== prevDrumV) {
          prevDrumV = v;
          if (!isRated) {
            isRated = true;
            ratingClearBtn.hidden = false;
            drumOuterEl.classList.remove("is-unrated");
          }
          ratingInput.value = String(v);
          if ("vibrate" in navigator) navigator.vibrate(1);
        }

        // Debounced JS snap (replaces CSS scroll-snap-type: mandatory, que en
        // iOS no llega al último item). Mientras hay dedo apoyado o mouse drag,
        // no snappeamos — esperamos a que se suelte.
        if (scrollSnapTimer) clearTimeout(scrollSnapTimer);
        scrollSnapTimer = window.setTimeout(() => {
          if (isDragging || isTouching) return;
          snapToNearest();
        }, 120);
      },
      { passive: true },
    );

    // Track de dedo apoyado: sin esto, el timer de 120ms snappea bajo el dedo
    // si el usuario pausa el movimiento sin soltar.
    drumEl.addEventListener("touchstart", () => {
      isTouching = true;
      if (scrollSnapTimer) clearTimeout(scrollSnapTimer);
    }, { passive: true });
    const onTouchRelease = () => {
      isTouching = false;
      // Snap inmediato al soltar: ya sabemos que el gesto terminó, no hay nada
      // que debouncear. El timer del scroll se cancela para que no dispare otro.
      if (scrollSnapTimer) clearTimeout(scrollSnapTimer);
      if (!isDragging) snapToNearest();
    };
    drumEl.addEventListener("touchend", onTouchRelease, { passive: true });
    drumEl.addEventListener("touchcancel", onTouchRelease, { passive: true });

    // Wheel support for desktop
    let wheelSnapTimer: number | undefined;
    drumEl.addEventListener(
      "wheel",
      (e) => {
        e.preventDefault();
        drumEl.scrollLeft += e.deltaY !== 0 ? e.deltaY : e.deltaX;
        // Debounced snap-to-nearest after wheel stops
        if (wheelSnapTimer) clearTimeout(wheelSnapTimer);
        wheelSnapTimer = window.setTimeout(() => {
          drumEl.scrollTo({ left: scrollLeftFor(idxFromScrollLeft()), behavior: "smooth" });
        }, 120);
      },
      { passive: false },
    );

    // Mouse drag support for desktop (touch already scrolls natively)
    let isDragging = false;
    let dragStartX = 0;
    let dragStartScroll = 0;
    let dragMoved = false;

    drumEl.addEventListener("pointerdown", (e) => {
      if (e.pointerType === "touch") return;
      if (drumOuterEl.classList.contains("is-unrated")) return;
      isDragging = true;
      dragMoved = false;
      dragStartX = e.clientX;
      dragStartScroll = drumEl.scrollLeft;
      try { drumEl.setPointerCapture(e.pointerId); } catch {}
    });

    const DRAG_SPEED = 1.8; // multiplier so reaching the edges doesn't require a huge drag

    drumEl.addEventListener("pointermove", (e) => {
      if (!isDragging) return;
      const dx = e.clientX - dragStartX;
      if (Math.abs(dx) > 2) dragMoved = true;
      drumEl.scrollLeft = dragStartScroll - dx * DRAG_SPEED;
    });

    const endDrag = (e: PointerEvent) => {
      if (!isDragging) return;
      isDragging = false;
      try { drumEl.releasePointerCapture(e.pointerId); } catch {}
      // Custom JS scroll doesn't trigger CSS scroll-snap. Snap to nearest item manually
      // so releases always land exactly on a value (including the max, 10).
      drumEl.scrollTo({ left: scrollLeftFor(idxFromScrollLeft()), behavior: "smooth" });
      if (dragMoved) {
        const stopClick = (ev: Event) => { ev.stopPropagation(); };
        window.addEventListener("click", stopClick, { capture: true, once: true });
      }
    };
    drumEl.addEventListener("pointerup", endDrag);
    drumEl.addEventListener("pointercancel", endDrag);

    function initDrumForValue(v: number) {
      buildDrum();
      syncDrumPadding();
      const idx = Math.round((v - MIN_V) * 10);
      prevDrumV = -1;
      prevCenter = -1;
      drumEl.scrollLeft = scrollLeftFor(idx);
      requestAnimationFrame(() => {
        updateDrumVisuals(idxFromScrollLeft());
      });
    }

    nameInput.oninput = () => {
      const pos = nameInput.selectionStart;
      nameInput.value = nameInput.value.toUpperCase();
      nameInput.setSelectionRange(pos, pos);
    };

    form.onsubmit = (e) => {
      e.preventDefault();
      errorEl.textContent = "";

      const name = nameInput.value.trim();
      if (!name) {
        errorEl.textContent = "El nombre del plato es obligatorio.";
        nameInput.focus();
        return;
      }

      const restaurantId = restaurantIdInput.value;
      const id = idInput.value;

      const typeId = typeIdInput.value || null;
      const duplicate = getDishesByRestaurant(restaurantId).find(
        (d) =>
          d.name.trim().toLowerCase() === name.toLowerCase() &&
          d.typeId === typeId &&
          d.id !== id,
      );
      if (duplicate) {
        errorEl.textContent =
          "Ya existe un plato con ese nombre y tipo en este restaurante.";
        nameInput.focus();
        return;
      }

      const rating = isRated ? parseFloat(ratingInput.value) : null;
      const notes = notesInput.value.trim();

      // Cerrar ANTES de emitir: garantiza que el modal cierra aunque
      // el listener del evento lance una excepción.
      close();

      if (id) {
        const updated = updateDish(id, { name, rating, notes, typeId });
        if (updated) emit("dish:updated", updated);
      } else {
        emit(
          "dish:created",
          createDish({ restaurantId, typeId, name, rating, notes }),
        );
      }
    };

    // Actualizar API global con referencias frescas al DOM actual
    (window as any).dishForm = { open, close };
  });
</script>
