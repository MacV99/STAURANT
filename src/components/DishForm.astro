<div id="dish-form-overlay" class="overlay" aria-modal="true" role="dialog">
  <div class="form-box flex-column">
    <div class="form-header flex-row">
      <h2 id="dish-form-title">Nuevo plato</h2>
      <button
        id="dish-form-close"
        class="btn-close btn-icon-close boton2"
        aria-label="Cerrar"
      >
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <form id="dish-form" class="flex-column" novalidate>
      <input type="hidden" id="df-id" />
      <input type="hidden" id="df-restaurant-id" />
      <input type="hidden" id="df-type-id" />
      <input type="hidden" id="df-rating" value="5" />

      <div class="type-field flex-column">
        <span class="label-text flex-row"
          >Tipo de plato <span class="optional">(opcional)</span></span
        >
        <div class="type-combobox" id="df-type-combobox">
          <div class="type-input-wrap flex-row">
            <input
              type="text"
              id="df-type-search"
              class="type-search-input"
              placeholder="Selecciona una etiqueta"
              autocomplete="off"
              spellcheck="false"
            />
            <button
              type="button"
              id="df-type-clear"
              class="type-clear-btn"
              hidden
              aria-label="Quitar tipo"
            >
              <i class="bi bi-x-lg"></i>
            </button>
            <span class="type-chevron" aria-hidden="true"
              ><i class="bi bi-chevron-down"></i></span
            >
          </div>
          <div id="df-type-dropdown" class="type-dropdown" hidden></div>
        </div>
      </div>

      <label for="df-name">
        <span class="label-text flex-row"
          >Nombre del plato <span class="required">*</span></span
        >
        <input
          type="text"
          id="df-name"
          required
          placeholder="Bandeja paisa, Sushi roll..."
        />
      </label>

      <div class="rating-field flex-column">
        <div class="rating-label-row flex-row">
          <span class="rating-label"
            >Calificación <span class="optional">(opcional)</span></span
          >
          <button
            type="button"
            id="df-rating-clear"
            class="rating-clear-link"
            hidden
          >
            Quitar
          </button>
        </div>
        <div class="drum-outer is-unrated" id="df-drum-outer">
          <div class="drum-picker" id="df-rating-drum">
            <div class="drum-track" id="df-drum-track"></div>
          </div>
          <div class="drum-hint">
            <i class="bi bi-star"></i>
            <span>Toca para calificar</span>
          </div>
        </div>
      </div>

      <label for="df-notes">
        <span class="label-text flex-row">Notas</span>
        <textarea
          id="df-notes"
          rows="2"
          placeholder="Sabor, presentación, lo que quieras recordar..."
        ></textarea>
      </label>

      <p id="df-error" class="form-error" aria-live="polite"></p>

      <div class="form-footer flex-row">
        <button type="button" id="dish-form-cancel" class="boton2"
          >Cancelar</button
        >
        <button type="submit" class="boton">Guardar</button>
      </div>
    </form>
  </div>
</div>

<style>
  /* Elementos renderizados estáticamente en el template → scoped normal */

  .form-box {
    background: var(--clr-white);
    border: solid 1px var(--clr-border);
    border-radius: 20px;
    padding: 24px 20px;
    width: 92%;
    max-width: 420px;
    max-height: 90dvh;
    overflow-y: auto;
    align-items: stretch;
    gap: 0;
  }

  .form-header {
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .form-header h2 {
    font-size: 1.1rem;
    letter-spacing: 1px;
    color: var(--clr-text);
  }

  form {
    align-items: stretch;
    gap: 14px;
  }

  label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-text);
    text-transform: uppercase;
    gap: 0;
  }

  .label-text {
    justify-content: flex-start;
    gap: 3px;
    margin-bottom: 5px;
  }

  label input,
  label textarea {
    border-radius: var(--border-radius);
    width: 100%;
  }

  .rating-field {
    align-items: stretch;
    gap: 8px;
  }

  .rating-label-row {
    justify-content: space-between;
    align-items: center;
  }

  .rating-label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-text);
    text-transform: uppercase;
  }

  .rating-clear-link {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.75rem;
    color: var(--clr-text);
    opacity: 0.45;
    padding: 0;
    transition: opacity var(--transition);
  }

  @media (hover: hover) {
    .rating-clear-link:hover {
      opacity: 1;
      color: var(--clr-danger);
    }
  }

  /* ── Drum picker ─────────────────────────────────────────────────────────── */

  .drum-outer {
    position: relative;
    display: flex;
    align-items: stretch;
    border-radius: 16px;
    background: var(--clr-white2);
    border: 1.5px dashed var(--clr-border2);
    transition:
      border-color var(--transition),
      background var(--transition);
    height: 72px;
    overflow: hidden;
    cursor: pointer;
  }

  .drum-outer:not(.is-unrated) {
    border-style: solid;
    background: var(--clr-white);
    cursor: default;
  }

  .drum-hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--clr-primary);
    pointer-events: none;
    transition: opacity 0.2s ease;
    animation: drum-hint-pulse 2s ease-in-out infinite;
  }

  .drum-hint i {
    font-size: 1.15rem;
  }

  .drum-outer:not(.is-unrated) .drum-hint {
    opacity: 0;
    animation: none;
  }

  @keyframes drum-hint-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.95; }
  }

  .drum-picker {
    flex: 1;
    min-width: 0;
    overflow-x: scroll;
    overflow-y: hidden;
    scrollbar-width: none;
    /* Snap handled fully in JS (debounced on scroll-end). Native mandatory snap
       on iOS Safari refuses to land on the last item when it's near edge — caused
       picker to cap at ~9.7. */
    overscroll-behavior-x: contain;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 22%,
      black 78%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      black 22%,
      black 78%,
      transparent
    );
    pointer-events: none;
  }

  .drum-outer:not(.is-unrated) .drum-picker {
    pointer-events: auto;
    cursor: grab;
  }

  /* Sin calificación: ocultar items para que solo se vea el hint */
  .drum-outer.is-unrated .drum-picker {
    opacity: 0;
  }

  .drum-picker::-webkit-scrollbar {
    display: none;
  }
  .drum-outer:not(.is-unrated) .drum-picker:active {
    cursor: grabbing;
  }

  .drum-track {
    display: flex;
    align-items: center;
    height: 100%;
    /* width: max-content → track se dimensiona al ancho real de sus items + spacers.
       Sin esto, drum-track adopta ancho del padre y los items desbordan, lo que en
       iOS Safari hace que scrollWidth no cubra el último ítem. */
    width: max-content;
  }

  /* ── Combobox de tipo — elementos estáticos ───────────────────────────── */

  .type-field {
    align-items: stretch;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-text);
    text-transform: uppercase;
  }

  .type-combobox {
    position: relative;
  }

  .type-input-wrap {
    border: 1.5px solid var(--clr-border);
    border-radius: var(--border-radius);
    background: var(--clr-white);
    overflow: hidden;
    transition: border-color 0.12s ease;
  }

  .type-input-wrap:focus-within {
    border-color: var(--clr-border2);
  }

  .type-search-input {
    flex: 1;
    border: none !important;
    background: transparent !important;
    outline: none !important;
    box-shadow: none !important;
    padding: 10px 12px;
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--clr-text);
    min-width: 0;
  }

  .type-search-input::placeholder {
    text-transform: none;
    color: var(--clr-text);
    opacity: 0.5;
    font-weight: 400;
  }

  .type-clear-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 6px;
    color: var(--clr-text);
    opacity: 0.5;
    font-size: 0.75rem;
    flex-shrink: 0;
    transition: opacity 0.12s ease;
  }

  .type-chevron {
    padding: 0 10px 0 4px;
    color: var(--clr-text);
    opacity: 0.4;
    font-size: 0.75rem;
    flex-shrink: 0;
    pointer-events: none;
    transition: transform 0.15s ease;
  }

  .type-combobox.is-open .type-chevron {
    transform: rotate(180deg);
  }

  .type-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: var(--clr-white);
    border: 1.5px solid var(--clr-border);
    border-radius: var(--border-radius);
    z-index: 200;
    max-height: 220px;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  /* ── Resto ──────────────────────────────────────────────────────────────── */

  .required {
    color: #e05050;
    font-weight: 700;
  }

  .optional {
    font-weight: 400;
    color: var(--clr-text);
    text-transform: none;
    letter-spacing: 0;
  }

  .form-error {
    font-size: 0.85rem;
    color: #e05050;
    min-height: 1.2em;
  }

  .form-footer {
    justify-content: flex-end;
    gap: 10px;
    margin-top: 6px;
  }

  @media (hover: hover) {
    .type-clear-btn:hover {
      opacity: 1;
    }
  }

  @media (min-width: 768px) {
    .form-box {
      padding: 28px 28px;
    }
  }
</style>

