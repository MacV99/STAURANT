  }

  .type-combobox.is-open .type-chevron {
    transform: rotate(180deg);
  }

  .type-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: var(--clr-white);
    border: 1.5px solid var(--clr-border);
    border-radius: var(--border-radius);
    z-index: 200;
    max-height: 220px;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  /* ── Resto ──────────────────────────────────────────────────────────────── */

  .required {
    color: #e05050;
    font-weight: 700;
  }

  .optional {
    font-weight: 400;
    color: var(--clr-text);
    text-transform: none;
    letter-spacing: 0;
  }

  .form-error {
    font-size: 0.85rem;
    color: #e05050;
    min-height: 1.2em;
  }

  .form-footer {
    justify-content: flex-end;
    gap: 10px;
    margin-top: 6px;
  }

  @media (hover: hover) {
    .type-clear-btn:hover {
      opacity: 1;
    }
  }

  @media (min-width: 768px) {
    .form-box {
      padding: 28px 28px;
    }
  }
</style>

