<div id="dish-form-overlay" class="overlay" aria-modal="true" role="dialog">
  <div class="form-box flex-column">
    <div class="form-header flex-row">
      <h2 id="dish-form-title">Nuevo plato</h2>
      <button id="dish-form-close" class="btn-close btn-icon-close boton2" aria-label="Cerrar">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <form id="dish-form" class="flex-column" novalidate>
      <input type="hidden" id="df-id" />
      <input type="hidden" id="df-restaurant-id" />
      <input type="hidden" id="df-type-id" />
      <input type="hidden" id="df-rating" value="7" />

      <div class="type-field flex-column">
        <span class="label-text flex-row"
          >Tipo de plato <span class="optional">(opcional)</span></span
        >
        <div class="type-combobox" id="df-type-combobox">
          <div class="type-input-wrap flex-row">
            <input
              type="text"
              id="df-type-search"
              class="type-search-input"
              placeholder="Selecciona una etiqueta"
              autocomplete="off"
              spellcheck="false"
            />
            <button
              type="button"
              id="df-type-clear"
              class="type-clear-btn"
              hidden
              aria-label="Quitar tipo"
            >
              <i class="bi bi-x-lg"></i>
            </button>
            <span class="type-chevron" aria-hidden="true"
              ><i class="bi bi-chevron-down"></i></span
            >
          </div>
          <div id="df-type-dropdown" class="type-dropdown" hidden></div>
        </div>
      </div>

      <label for="df-name">
        <span class="label-text flex-row"
          >Nombre del plato <span class="required">*</span></span
        >
        <input
          type="text"
          id="df-name"
          required
          placeholder="Bandeja paisa, Sushi roll..."
        />
      </label>

      <div class="rating-field flex-column">
        <div class="rating-label-row flex-row">
          <span class="rating-label">Calificación <span class="optional">(opcional)</span></span>
          <button type="button" id="df-rating-clear" class="rating-clear-link" hidden>
            Quitar
          </button>
        </div>
        <div class="rating-row flex-column">
          <span id="df-rating-value" class="rating-value rating-value--empty flex-row">
            <i class="bi bi-star"></i>
          </span>
          <div class="rating-ruler-wrap">
            <div class="ruler-indicator"></div>
            <div class="rating-ruler" id="df-rating-ruler">
              <div class="ruler-track" id="df-rating-track"></div>
            </div>
          </div>
        </div>
      </div>

      <label for="df-notes">
        <span class="label-text flex-row">Notas</span>
        <textarea
          id="df-notes"
          rows="2"
          placeholder="Sabor, presentación, lo que quieras recordar..."
        ></textarea>
      </label>

      <p id="df-error" class="form-error" aria-live="polite"></p>

      <div class="form-footer flex-row">
        <button type="button" id="dish-form-cancel" class="boton2"
          >Cancelar</button
        >
        <button type="submit" class="boton">Guardar</button>
      </div>
    </form>
  </div>
</div>

<style>
  /* Elementos renderizados estáticamente en el template → scoped normal */

  .form-box {
    background: var(--clr-white);
    border: solid 1px var(--clr-border);
    border-radius: 20px;
    padding: 24px 20px;
    width: 92%;
    max-width: 420px;
    max-height: 90dvh;
    overflow-y: auto;
    align-items: stretch;
    gap: 0;
  }

  .form-header {
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .form-header h2 {
    font-size: 1.1rem;
    letter-spacing: 1px;
    color: var(--clr-text);
  }

  form {
    align-items: stretch;
    gap: 14px;
  }

  label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-dark2);
    text-transform: uppercase;
    gap: 0;
  }

  .label-text {
    justify-content: flex-start;
    gap: 3px;
    margin-bottom: 5px;
  }

  label input,
  label textarea {
    border-radius: var(--border-radius);
    width: 100%;
  }

  .rating-field {
    align-items: stretch;
    gap: 8px;
  }

  .rating-label-row {
    justify-content: space-between;
    align-items: center;
  }

  .rating-label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-text);
    text-transform: uppercase;
  }

  .rating-clear-link {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.75rem;
    color: var(--clr-text);
    opacity: 0.45;
    padding: 0;
    transition: opacity var(--transition);
  }

  @media (hover: hover) {
    .rating-clear-link:hover {
      opacity: 1;
      color: var(--clr-danger);
    }
  }

  /* ── Rating card ────────────────────────────────────────────────────────── */

  .rating-row {
    align-items: center;
    gap: 10px;
    background: var(--clr-white2);
    border: 1.5px dashed var(--clr-border2);
    border-radius: 16px;
    padding: 16px 14px 14px;
    cursor: pointer;
    transition: border-color var(--transition), background var(--transition);
  }

  .rating-row:not(.is-unrated) {
    border-style: solid;
    cursor: default;
    background: var(--clr-white);
  }

  /* Big value bubble */
  .rating-value {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    font-weight: 800;
    font-size: 1.75rem;
    letter-spacing: -1px;
    flex-shrink: 0;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
  }

  .rating-value--empty {
    background: transparent;
    color: var(--clr-text);
    border: 2px dashed var(--clr-border2);
    font-size: 1.5rem;
    opacity: 0.65;
  }

  .rating-value.badge-low {
    background: var(--clr-danger-bg);
    color: var(--clr-danger);
    border: solid 2px color-mix(in srgb, var(--clr-danger-border) 50%, transparent);
    opacity: 1;
  }

  .rating-value.badge-mid {
    background: #fff3d6;
    color: #a06010;
    border: solid 2px #e8c55a;
    opacity: 1;
  }

  .rating-value.badge-high {
    background: #d8f5e2;
    color: #1a7a38;
    border: solid 2px #7dcf9e;
    opacity: 1;
  }

  /* ── Ruler picker ───────────────────────────────────────────────────────── */

  .rating-ruler-wrap {
    position: relative;
    width: 100%;
  }

  .ruler-indicator {
    position: absolute;
    top: 4px;
    bottom: 20px;
    left: 50%;
    width: 2px;
    transform: translateX(-50%);
    background: var(--clr-primary);
    border-radius: 2px;
    pointer-events: none;
    z-index: 2;
    opacity: 0.5;
  }

  .ruler-indicator::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: var(--clr-primary);
    opacity: 0.5;
  }

  .rating-ruler {
    width: 100%;
    height: 58px;
    overflow-x: scroll;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-snap-type: x mandatory;
    overscroll-behavior-x: contain;
    cursor: grab;
    -webkit-mask-image: linear-gradient(to right, transparent, black 16%, black 84%, transparent);
    mask-image: linear-gradient(to right, transparent, black 16%, black 84%, transparent);
  }

  .rating-ruler::-webkit-scrollbar { display: none; }
  .rating-ruler:active { cursor: grabbing; }

  .ruler-track {
    display: flex;
    align-items: flex-end;
    height: 100%;
    padding: 0 calc(50% - 12px);
  }

  /* ── Combobox de tipo — elementos estáticos ───────────────────────────── */

  .type-field {
    align-items: stretch;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-dark2);
    text-transform: uppercase;
  }

  .type-combobox {
    position: relative;
  }

  .type-input-wrap {
    border: 1.5px solid var(--clr-border);
    border-radius: var(--border-radius);
    background: var(--clr-white);
    overflow: hidden;
    transition: border-color 0.12s ease;
  }

  .type-input-wrap:focus-within {
    border-color: var(--clr-border2);
  }

  .type-search-input {
    flex: 1;
    border: none !important;
    background: transparent !important;
    outline: none !important;
    box-shadow: none !important;
    padding: 10px 12px;
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--clr-text);
    min-width: 0;
  }

  .type-search-input::placeholder {
    text-transform: none;
    color: var(--clr-text);
    opacity: 0.5;
    font-weight: 400;
  }

  .type-clear-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 6px;
    color: var(--clr-text);
    opacity: 0.5;
    font-size: 0.75rem;
    flex-shrink: 0;
    transition: opacity 0.12s ease;
  }

  .type-chevron {
    padding: 0 10px 0 4px;
    color: var(--clr-text);
    opacity: 0.4;
    font-size: 0.75rem;
    flex-shrink: 0;
    pointer-events: none;
