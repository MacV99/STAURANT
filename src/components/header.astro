---

---

<header class="header-bar">
  <a href="/" class="logo-link" aria-label="Inicio">
    <img src="/img/logo2.png" alt="Logo STAURANT" />
  </a>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const bottomNav = document.querySelector(
      ".mobile-bottom-nav",
    ) as HTMLElement | null;
    if (!bottomNav) return;

    bottomNav.addEventListener("click", (event) => {
      const actionBtn = (event.target as HTMLElement).closest(
        "[data-action]",
      ) as HTMLElement | null;
      if (!actionBtn) return;
      const action = actionBtn.dataset.action;
      if (!action) return;
      event.preventDefault();

      if (action === "create") {
        if (
          window.location.pathname === "/" ||
          window.location.pathname.endsWith("/index")
        ) {
          (window as any).restaurantForm?.open("create");
          return;
        }

        if (window.location.pathname.includes("/restaurante")) {
          const restaurantId = new URLSearchParams(window.location.search).get(
            "id",
          );
          if (restaurantId) {
            (window as any).dishForm?.open("create", restaurantId);
            return;
          }
        }

        window.location.href = "/";
      }
    });
  });
</script>

<style>
  .header-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    position: sticky;
    top: 10px;
    background: var(--clr-white);
    border: solid 1px var(--clr-border);
    border-radius: 20px;
    width: 95%;
    height: 72px;
    margin: 10px auto;
    padding: 12px 16px;
    transition: var(--transition);
    z-index: 100;
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
  }

  .logo-link img {
    width: 100%;
    height: auto;
    display: block;
    max-width: 100%;
  }

  @media (min-width: 768px) {
    .header-bar {
      width: 98%;
    }
  }
</style>
