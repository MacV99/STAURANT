---

---

<header class="header-bar">
  <a href="/" class="logo-link" aria-label="Inicio">
    <img src="/img/logo2.png" alt="Logo STAURANT" />
  </a>
</header>


<style>
  .header-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    position: sticky;
    top: 10px;
    background: var(--clr-white);
    border: solid 1px var(--clr-border);
    border-radius: 20px;
    width: 95%;
    height: 72px;
    margin: 10px auto;
    padding: 12px 16px;
    transition: var(--transition);
    z-index: 100;
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
  }

  .logo-link img {
    width: 100%;
    height: auto;
    display: block;
    max-width: 100%;
  }

  @media (min-width: 768px) {
    .header-bar {
      width: 98%;
    }
  }
</style>
